{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PCGMH47M5s6MbebWGdgBud","type":"tool_result","content":"     1→PRAGMA journal_mode=WAL;\n     2→PRAGMA foreign_keys=ON;\n     3→\n     4→-- Comptes bancaires\n     5→CREATE TABLE IF NOT EXISTS accounts (\n     6→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n     7→    name TEXT NOT NULL,\n     8→    account_number TEXT,\n     9→    bank_name TEXT,\n    10→    account_type TEXT CHECK(account_type IN ('checking', 'savings', 'credit_card', 'cash')) DEFAULT 'checking',\n    11→    currency TEXT DEFAULT 'EUR',\n    12→    initial_balance REAL DEFAULT 0,\n    13→    is_active BOOLEAN DEFAULT 1,\n    14→    created_at DATETIME DEFAULT CURRENT_TIMESTAMP\n    15→);\n    16→\n    17→-- Catégories de budget (Series)\n    18→CREATE TABLE IF NOT EXISTS budget_series (\n    19→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    20→    name TEXT NOT NULL,\n    21→    budget_area TEXT CHECK(budget_area IN ('income', 'recurring', 'variable', 'extras', 'savings', 'transfers')),\n    22→    target_amount REAL,\n    23→    day_of_month INTEGER,\n    24→    is_active BOOLEAN DEFAULT 1,\n    25→    description TEXT\n    26→);\n    27→\n    28→-- Sous-catégories\n    29→CREATE TABLE IF NOT EXISTS sub_series (\n    30→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    31→    series_id INTEGER NOT NULL REFERENCES budget_series(id) ON DELETE CASCADE,\n    32→    name TEXT NOT NULL\n    33→);\n    34→\n    35→-- Batches d'import pour pouvoir rollback\n    36→CREATE TABLE IF NOT EXISTS import_batches (\n    37→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    38→    filename TEXT NOT NULL,\n    39→    format TEXT CHECK(format IN ('ofx', 'qif', 'csv')),\n    40→    account_id INTEGER REFERENCES accounts(id),\n    41→    transaction_count INTEGER DEFAULT 0,\n    42→    imported_at DATETIME DEFAULT CURRENT_TIMESTAMP\n    43→);\n    44→\n    45→-- Transactions\n    46→CREATE TABLE IF NOT EXISTS transactions (\n    47→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    48→    account_id INTEGER NOT NULL REFERENCES accounts(id) ON DELETE CASCADE,\n    49→    date DATE NOT NULL,\n    50→    label TEXT NOT NULL,\n    51→    original_label TEXT,\n    52→    amount REAL NOT NULL,\n    53→    note TEXT,\n    54→    is_planned BOOLEAN DEFAULT 0,\n    55→    series_id INTEGER REFERENCES budget_series(id) ON DELETE SET NULL,\n    56→    sub_series_id INTEGER REFERENCES sub_series(id) ON DELETE SET NULL,\n    57→    import_batch_id INTEGER REFERENCES import_batches(id),\n    58→    fitid TEXT,\n    59→    created_at DATETIME DEFAULT CURRENT_TIMESTAMP\n    60→);\n    61→\n    62→-- Transactions splittées (une transaction → plusieurs catégories)\n    63→CREATE TABLE IF NOT EXISTS transaction_splits (\n    64→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    65→    transaction_id INTEGER NOT NULL REFERENCES transactions(id) ON DELETE CASCADE,\n    66→    series_id INTEGER NOT NULL REFERENCES budget_series(id),\n    67→    amount REAL NOT NULL,\n    68→    note TEXT\n    69→);\n    70→\n    71→-- Budget mensuel par série\n    72→CREATE TABLE IF NOT EXISTS monthly_budget (\n    73→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    74→    series_id INTEGER NOT NULL REFERENCES budget_series(id) ON DELETE CASCADE,\n    75→    year INTEGER NOT NULL,\n    76→    month INTEGER NOT NULL,\n    77→    planned_amount REAL NOT NULL,\n    78→    UNIQUE(series_id, year, month)\n    79→);\n    80→\n    81→-- Templates de transactions récurrentes\n    82→CREATE TABLE IF NOT EXISTS recurring_transactions (\n    83→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    84→    account_id INTEGER NOT NULL REFERENCES accounts(id),\n    85→    label TEXT NOT NULL,\n    86→    amount REAL NOT NULL,\n    87→    series_id INTEGER REFERENCES budget_series(id),\n    88→    frequency TEXT CHECK(frequency IN ('monthly', 'weekly', 'biweekly', 'quarterly', 'yearly')),\n    89→    day_of_month INTEGER,\n    90→    start_date DATE,\n    91→    end_date DATE,\n    92→    is_active BOOLEAN DEFAULT 1\n    93→);\n    94→\n    95→-- Projets / Objectifs\n    96→CREATE TABLE IF NOT EXISTS projects (\n    97→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    98→    name TEXT NOT NULL,\n    99→    target_amount REAL,\n   100→    target_date DATE,\n   101→    account_id INTEGER REFERENCES accounts(id) ON DELETE SET NULL,\n   102→    is_active BOOLEAN DEFAULT 1\n   103→);\n   104→\n   105→-- Items de projet\n   106→CREATE TABLE IF NOT EXISTS project_items (\n   107→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n   108→    project_id INTEGER NOT NULL REFERENCES projects(id) ON DELETE CASCADE,\n   109→    label TEXT NOT NULL,\n   110→    planned_amount REAL NOT NULL,\n   111→    month INTEGER,\n   112→    year INTEGER,\n   113→    series_id INTEGER REFERENCES budget_series(id) ON DELETE SET NULL\n   114→);\n   115→\n   116→-- Tags transversaux\n   117→CREATE TABLE IF NOT EXISTS tags (\n   118→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n   119→    name TEXT NOT NULL UNIQUE\n   120→);\n   121→\n   122→CREATE TABLE IF NOT EXISTS transaction_tags (\n   123→    transaction_id INTEGER NOT NULL REFERENCES transactions(id) ON DELETE CASCADE,\n   124→    tag_id INTEGER NOT NULL REFERENCES tags(id) ON DELETE CASCADE,\n   125→    PRIMARY KEY (transaction_id, tag_id)\n   126→);\n   127→\n   128→-- Règles de catégorisation auto\n   129→CREATE TABLE IF NOT EXISTS categorization_rules (\n   130→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n   131→    pattern TEXT NOT NULL UNIQUE,\n   132→    series_id INTEGER NOT NULL REFERENCES budget_series(id),\n   133→    sub_series_id INTEGER REFERENCES sub_series(id),\n   134→    match_count INTEGER DEFAULT 0,\n   135→    created_at DATETIME DEFAULT CURRENT_TIMESTAMP\n   136→);\n   137→\n   138→-- Index pour la performance\n   139→CREATE INDEX IF NOT EXISTS idx_transactions_date ON transactions(date);\n   140→CREATE INDEX IF NOT EXISTS idx_transactions_account ON transactions(account_id);\n   141→CREATE INDEX IF NOT EXISTS idx_transactions_series ON transactions(series_id);\n   142→CREATE INDEX IF NOT EXISTS idx_transactions_fitid ON transactions(fitid);\n   143→CREATE INDEX IF NOT EXISTS idx_monthly_budget_period ON monthly_budget(year, month);\n   144→CREATE INDEX IF NOT EXISTS idx_project_items_project ON project_items(project_id);\n   145→"}]},"parent_tool_use_id":"toolu_013FYsv4qogmjhYcHQvXwSGZ","session_id":"5670e2f2-2b23-453d-b13a-df268ffbafbe","uuid":"72f2fb64-b326-4f72-ae08-e2ba0c5b4ed7","timestamp":"2026-03-17T15:42:35.446Z"}
