e,\n    53→\t\t\t\taccount_number: formNumber || undefined,\n    54→\t\t\t\tbank_name: formBank || undefined,\n    55→\t\t\t\taccount_type: formType,\n    56→\t\t\t\tinitial_balance: formBalance\n    57→\t\t\t});\n    58→\t\t}\n    59→\t\tshowForm = false;\n    60→\t}\n    61→\n    62→\tasync function handleDelete(id: number) {\n    63→\t\tawait accountStore.remove(id);\n    64→\t}\n    65→</script>\n    66→\n    67→<svelte:head>\n    68→\t<title>Comptes — BudgetView</title>\n    69→</svelte:head>\n    70→\n    71→<div class=\"space-y-6\">\n    72→\t<div class=\"flex items-center justify-between\">\n    73→\t\t<h1 class=\"text-2xl font-bold text-text-primary\">Comptes</h1>\n    74→\t\t<button\n    75→\t\t\tonclick={openCreate}\n    76→\t\t\tclass=\"flex items-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent-hover\"\n    77→\t\t>\n    78→\t\t\t<Plus size={16} />\n    79→\t\t\tNouveau compte\n    80→\t\t</button>\n    81→\t</div>\n    82→\n    83→\t{#if accountStore.accounts.length === 0 && !accountStore.loading}\n    84→\t\t<div class=\"flex flex-col items-center justify-center rounded-xl border border-border bg-bg-card p-12\">\n    85→\t\t\t<Landmark size={48} class=\"mb-4 text-text-muted\" />\n    86→\t\t\t<p class=\"text-lg font-medium text-text-secondary\">Aucun compte</p>\n    87→\t\t\t<p class=\"text-sm text-text-muted\">Ajoutez votre premier compte bancaire pour commencer</p>\n    88→\t\t</div>\n    89→\t{:else}\n    90→\t\t<!-- Solde total -->\n    91→\t\t<div class=\"rounded-xl border border-border bg-bg-card p-4\">\n    92→\t\t\t<span class=\"text-sm text-text-secondary\">Solde total</span>\n    93→\t\t\t<span class=\"ml-2 text-xl font-bold text-text-primary\">{formatCurrency(accountStore.totalBalance)}</span>\n    94→\t\t</div>\n    95→\n    96→\t\t<!-- Liste des comptes -->\n    97→\t\t<div class=\"space-y-3\">\n    98→\t\t\t{#each accountStore.accounts as account (account.id)}\n    99→\t\t\t\t<div class=\"flex items-center justify-between rounded-xl border border-border bg-bg-card p-4 transition-colors hover:bg-bg-hover\">\n   100→\t\t\t\t\t<div class=\"flex items-center gap-4\">\n   101→\t\t\t\t\t\t<div class=\"flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10\">\n   102→\t\t\t\t\t\t\t<Landmark size={20} class=\"text-accent\" />\n   103→\t\t\t\t\t\t</div>\n   104→\t\t\t\t\t\t<div>\n   105→\t\t\t\t\t\t\t<p class=\"font-medium text-text-primary\">{account.name}</p>\n   106→\t\t\t\t\t\t\t<p class=\"text-sm text-text-secondary\">\n   107→\t\t\t\t\t\t\t\t{ACCOUNT_TYPE_LABELS[account.account_type]}\n   108→\t\t\t\t\t\t\t\t{#if account.bank_name}\n   109→\t\t\t\t\t\t\t\t\t&middot; {account.bank_name}\n   110→\t\t\t\t\t\t\t\t{/if}\n   111→\t\t\t\t\t\t\t\t{#if account.account_number}\n   112→\t\t\t\t\t\t\t\t\t&middot; {account.account_number}\n   113→\t\t\t\t\t\t\t\t{/if}\n   114→\t\t\t\t\t\t\t</p>\n   115→\t\t\t\t\t\t</div>\n   116→\t\t\t\t\t</div>\n   117→\t\t\t\t\t<div class=\"flex items-center gap-3\">\n   118→\t\t\t\t\t\t<span class=\"text-lg font-semibold {account.initial_balance >= 0 ? 'text-income' : 'text-expense'}\">\n   119→\t\t\t\t\t\t\t{formatCurrency(account.initial_balance)}\n   120→\t\t\t\t\t\t</span>\n   121→\t\t\t\t\t\t<button onclick={() => openEdit(account)} class=\"rounded-lg p-2 text-text-muted transition-colors hover:bg-bg-hover hover:text-text-primary\">\n   122→\t\t\t\t\t\t\t<Pencil size={16} />\n   123→\t\t\t\t\t\t</button>\n   124→\t\t\t\t\t\t<button onclick={() => handleDelete(account.id)} class=\"rounded-lg p-2 text-text-muted transition-colors hover:bg-bg-hover hover:text-danger\">\n   125→\t\t\t\t\t\t\t<Trash2 size={16} />\n   126→\t\t\t\t\t\t</button>\n   127→\t\t\t\t\t</div>\n   128→\t\t\t\t</div>\n   129→\t\t\t{/each}\n   130→\t\t</div>\n   131→\t{/if}\n   132→</div>\n   133→\n   134→<!-- Modal formulaire -->\n   135→{#if showForm}\n   136→\t<div class=\"fixed inset-0 z-50 flex items-center justify-center bg-black