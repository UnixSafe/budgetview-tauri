ues.push(account.bank_name); }\n    42→\t\tif (account.account_type !== undefined) { fields.push(`account_type = $${paramIndex++}`); values.push(account.account_type); }\n    43→\t\tif (account.initial_balance !== undefined) { fields.push(`initial_balance = $${paramIndex++}`); values.push(account.initial_balance); }\n    44→\n    45→\t\tif (fields.length > 0) {\n    46→\t\t\tvalues.push(id);\n    47→\t\t\tawait db.execute(\n    48→\t\t\t\t`UPDATE accounts SET ${fields.join(', ')} WHERE id = $${paramIndex}`,\n    49→\t\t\t\tvalues\n    50→\t\t\t);\n    51→\t\t\tawait this.loadAccounts();\n    52→\t\t}\n    53→\t}\n    54→\n    55→\tasync deleteAccount(id: number) {\n    56→\t\tconst db = await getDb();\n    57→\t\tawait db.execute('UPDATE accounts SET is_active = 0 WHERE id = $1', [id]);\n    58→\t\tawait this.loadAccounts();\n    59→\t}\n    60→\n    61→\tget totalBalance(): number {\n    62→\t\treturn this.accounts.reduce((sum, a) => sum + a.initial_balance, 0);\n    63→\t}\n    64→}\n    65→\n    66→export const accountStore = new AccountStore();\n    67→"}]},"parent_tool_use_id":null,"session_id":"50b61ee4-7d36-4fa5-a842-f47291a9b569","uuid":"d2c07394-e611-4918-b483-9de532ac64ed","timestamp":"2026-03-17T15:27:27.129Z","tool_use_result":{"type":"text","file":{"filePath":"/home/jeremy/Documents/budgetview-tauri/src/lib/stores/accounts.ts","content":"import { getDb } from './db';\nimport type { Account } from '$lib/types';\n\nclass AccountStore {\n\taccounts = $state<Account[]>([]);\n\tloading = $state(false);\n\terror = $state<string | null>(null);\n\n\tasync loadAccounts() {\n\t\tthis.loading = true;\n\t\tthis.error = null;\n\t\ttry {\n\t\t\tconst db = await getDb();\n\t\t\tthis.accounts = await db.select<Account[]>(\n\t\t\t\t'SELECT * FROM accounts WHERE is_active = 1 ORDER BY name'\n\t\t\t);\n\t\t} catch (e) {\n\t\t\tthis.error = e instanceof Error ? e.message : 'Erreur inconnue';\n\t\t} finally {\n\t\t\tthis.loading = false;\n\t\t}\n\t}\n\n\tasync createAccount(account: Omit<Account, 'id' | 'created_at' | 'is_active'>) {\n\t\tconst db = await getDb();\n\t\tawait db.execute(\n\t\t\t'INSERT INTO accounts (name, account_number, bank_name, account_type, initial_balance) VALUES ($1, $2, $3, $4, $5)',\n\t\t\t[account.name, account.account_number, account.bank_name, account.account_type, account.initial_balance]\n\t\t);\n\t\tawait this.loadAccounts();\n\t}\n\n\tasync updateAccount(id: number, account: Partial<Omit<Account, 'id' | 'created_at'>>) {\n\t\tconst db = await getDb();\n\t\tconst fields: string[] = [];\n\t\tconst values: unknown[] = [];\n\t\tlet paramIndex = 1;\n\n\t\tif (account.name !== undefined) { fields.push(`name = $${paramIndex++}`); values.push(account.name); }\n\t\tif (account.account_number !== undefined) { fields.push(`account_number = $${paramIndex++}`); values.push(account.account_number); }\n\t\tif (account.bank_name !== undefined) { fields.push(`bank_name = $${paramIndex++}`); values.push(account.bank_name); }\n\t\tif (account.account_type !== undefined) { fields.push(`account_type = $${paramIndex++}`); values.push(account.account_type); }\n\t\tif (account.initial_balance !== undefined) { fields.push(`initial_balance = $${paramIndex++}`); values.push(account.initial_balance); }\n\n\t\tif (fields.length > 0) {\n\t\t\tvalues.push(id);\n\t\t\tawait db.execute(\n\t\t\t\t`UPDATE accounts SET ${fields.join(', ')} WHERE id = $${paramIndex}`,\n\t\t\t\tvalues\n\t\t\t);\n\t\t\tawait this.loadAccounts();\n\t\t}\n\t}\n\n\tasync deleteAccount(id: number) {\n\t\tconst db = await getDb();\n\t\tawait db.execute('UPDATE accounts SET is_active = 0 WHERE id = $1', [id]);\n\t\tawait this.loadAccounts();\n\t}\n\n\tget totalBalance(): number {\n\t\treturn this.accounts.reduce((sum, a) => sum + a.initial_balance, 0);\n\t}\n}\n\nexport const accountStore = new AccountStore();\n","numLines":67,"startLine":1,"totalLines":67}}}
