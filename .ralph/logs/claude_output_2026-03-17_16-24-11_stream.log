e = 0 WHERE id = $1', [id]);\n\t\tawait this.load();\n\t}\n\n\tgetBalance(account: Account): number {\n\t\treturn account.initial_balance;\n\t}\n\n\tget totalBalance(): number {\n\t\treturn this.accounts.reduce((sum, a) => sum + a.initial_balance, 0);\n\t}\n}\n\nexport const accountStore = new AccountStore();\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":318,"cache_read_input_tokens":48630,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":318},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"50b61ee4-7d36-4fa5-a842-f47291a9b569","uuid":"d1c8af10-971c-4060-8a3f-24b61104b94f"}
