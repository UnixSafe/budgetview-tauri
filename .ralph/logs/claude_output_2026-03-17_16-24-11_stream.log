\t\t\t\t\t\tclass=\"h-1.5 rounded-full {over ? 'bg-danger' : 'bg-accent'}\"\n\t\t\t\t\t\t\t\tstyle=\"width: {pct}%\"\n\t\t\t\t\t\t\t></div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t{/each}\n\t\t\t</div>\n\t\t</div>\n\t{/if}\n</div>\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3989,"cache_read_input_tokens":60496,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3989},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"50b61ee4-7d36-4fa5-a842-f47291a9b569","uuid":"2c5f0143-01d2-4c45-8455-f84144380012"}
