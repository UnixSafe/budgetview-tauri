{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RKDwkF2LsQcBV8oJFSW3UB","type":"tool_result","content":"     1→-- Comptes bancaires\n     2→CREATE TABLE IF NOT EXISTS accounts (\n     3→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n     4→    name TEXT NOT NULL,\n     5→    account_number TEXT,\n     6→    bank_name TEXT,\n     7→    account_type TEXT CHECK(account_type IN ('checking', 'savings', 'credit_card', 'cash')) DEFAULT 'checking',\n     8→    initial_balance REAL DEFAULT 0,\n     9→    is_active BOOLEAN DEFAULT 1,\n    10→    created_at DATETIME DEFAULT CURRENT_TIMESTAMP\n    11→);\n    12→\n    13→-- Catégories de budget (Series)\n    14→CREATE TABLE IF NOT EXISTS budget_series (\n    15→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    16→    name TEXT NOT NULL,\n    17→    budget_area TEXT CHECK(budget_area IN ('income', 'recurring', 'variable', 'extras', 'savings', 'transfers')),\n    18→    target_amount REAL,\n    19→    day_of_month INTEGER,\n    20→    is_active BOOLEAN DEFAULT 1,\n    21→    profile_type TEXT DEFAULT 'IRREGULAR',\n    22→    description TEXT\n    23→);\n    24→\n    25→-- Sous-catégories\n    26→CREATE TABLE IF NOT EXISTS sub_series (\n    27→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    28→    series_id INTEGER NOT NULL REFERENCES budget_series(id) ON DELETE CASCADE,\n    29→    name TEXT NOT NULL\n    30→);\n    31→\n    32→-- Transactions\n    33→CREATE TABLE IF NOT EXISTS transactions (\n    34→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    35→    account_id INTEGER NOT NULL REFERENCES accounts(id) ON DELETE CASCADE,\n    36→    date DATE NOT NULL,\n    37→    label TEXT NOT NULL,\n    38→    original_label TEXT,\n    39→    amount REAL NOT NULL,\n    40→    note TEXT,\n    41→    is_planned BOOLEAN DEFAULT 0,\n    42→    series_id INTEGER REFERENCES budget_series(id) ON DELETE SET NULL,\n    43→    sub_series_id INTEGER REFERENCES sub_series(id) ON DELETE SET NULL,\n    44→    created_at DATETIME DEFAULT CURRENT_TIMESTAMP\n    45→);\n    46→\n    47→-- Budget mensuel par série\n    48→CREATE TABLE IF NOT EXISTS monthly_budget (\n    49→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    50→    series_id INTEGER NOT NULL REFERENCES budget_series(id) ON DELETE CASCADE,\n    51→    year INTEGER NOT NULL,\n    52→    month INTEGER NOT NULL,\n    53→    planned_amount REAL NOT NULL,\n    54→    UNIQUE(series_id, year, month)\n    55→);\n    56→\n    57→-- Projets / Objectifs\n    58→CREATE TABLE IF NOT EXISTS projects (\n    59→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    60→    name TEXT NOT NULL,\n    61→    target_amount REAL,\n    62→    target_date DATE,\n    63→    account_id INTEGER REFERENCES accounts(id) ON DELETE SET NULL,\n    64→    image_path TEXT,\n    65→    is_active BOOLEAN DEFAULT 1\n    66→);\n    67→\n    68→-- Items de projet\n    69→CREATE TABLE IF NOT EXISTS project_items (\n    70→    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    71→    project_id INTEGER NOT NULL REFERENCES projects(id) ON DELETE CASCADE,\n    72→    label TEXT NOT NULL,\n    73→    planned_amount REAL NOT NULL,\n    74→    month INTEGER,\n    75→    year INTEGER,\n    76→    series_id INTEGER REFERENCES budget_series(id) ON DELETE SET NULL\n    77→);\n    78→\n    79→-- Index pour les requêtes fréquentes\n    80→CREATE INDEX IF NOT EXISTS idx_transactions_account ON transactions(account_id);\n    81→CREATE INDEX IF NOT EXISTS idx_transactions_date ON transactions(date);\n    82→CREATE INDEX IF NOT EXISTS idx_transactions_series ON transactions(series_id);\n    83→CREATE INDEX IF NOT EXISTS idx_monthly_budget_series ON monthly_budget(series_id, year, month);\n    84→CREATE INDEX IF NOT EXISTS idx_project_items_project ON project_items(project_id);\n    85→"}]},"parent_tool_use_id":null,"session_id":"50b61ee4-7d36-4fa5-a842-f47291a9b569","uuid":"5d165ce6-1f98-421a-ba96-bc3398f43cad","timestamp":"2026-03-17T15:26:02.127Z","tool_use_result":{"type":"text","file":{"filePath":"/home/jeremy/Documents/budgetview-tauri/src-tauri/migrations/001_initial_schema.sql","content":"-- Comptes bancaires\nCREATE TABLE IF NOT EXISTS accounts (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    name TEXT NOT NULL,\n    account_number TEXT,\n    bank_name TEXT,\n    account_type TEXT CHECK(account_type IN ('checking', 'savings', 'credit_card', 'cash')) DEFAULT 'checking',\n    initial_balance REAL DEFAULT 0,\n    is_active BOOLEAN DEFAULT 1,\n    created_at DATETIME DEFAULT CURRENT_TIMESTAMP\n);\n\n-- Catégories de budget (Series)\nCREATE TABLE IF NOT EXISTS budget_series (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    name TEXT NOT NULL,\n    budget_area TEXT CHECK(budget_area IN ('income', 'recurring', 'variable', 'extras', 'savings', 'transfers')),\n    target_amount REAL,\n    day_of_month INTEGER,\n    is_active BOOLEAN DEFAULT 1,\n    profile_type TEXT DEFAULT 'IRREGULAR',\n    description TEXT\n);\n\n-- Sous-catégories\nCREATE TABLE IF NOT EXISTS sub_series (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    series_id INTEGER NOT NULL REFERENCES budget_series(id) ON DELETE CASCADE,\n    name TEXT NOT NULL\n);\n\n-- Transactions\nCREATE TABLE IF NOT EXISTS transactions (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    account_id INTEGER NOT NULL REFERENCES accounts(id) ON DELETE CASCADE,\n    date DATE NOT NULL,\n    label TEXT NOT NULL,\n    original_label TEXT,\n    amount REAL NOT NULL,\n    note TEXT,\n    is_planned BOOLEAN DEFAULT 0,\n    series_id INTEGER REFERENCES budget_series(id) ON DELETE SET NULL,\n    sub_series_id INTEGER REFERENCES sub_series(id) ON DELETE SET NULL,\n    created_at DATETIME DEFAULT CURRENT_TIMESTAMP\n);\n\n-- Budget mensuel par série\nCREATE TABLE IF NOT EXISTS monthly_budget (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    series_id INTEGER NOT NULL REFERENCES budget_series(id) ON DELETE CASCADE,\n    year INTEGER NOT NULL,\n    month INTEGER NOT NULL,\n    planned_amount REAL NOT NULL,\n    UNIQUE(series_id, year, month)\n);\n\n-- Projets / Objectifs\nCREATE TABLE IF NOT EXISTS projects (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    name TEXT NOT NULL,\n    target_amount REAL,\n    target_date DATE,\n    account_id INTEGER REFERENCES accounts(id) ON DELETE SET NULL,\n    image_path TEXT,\n    is_active BOOLEAN DEFAULT 1\n);\n\n-- Items de projet\nCREATE TABLE IF NOT EXISTS project_items (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    project_id INTEGER NOT NULL REFERENCES projects(id) ON DELETE CASCADE,\n    label TEXT NOT NULL,\n    planned_amount REAL NOT NULL,\n    month INTEGER,\n    year INTEGER,\n    series_id INTEGER REFERENCES budget_series(id) ON DELETE SET NULL\n);\n\n-- Index pour les requêtes fréquentes\nCREATE INDEX IF NOT EXISTS idx_transactions_account ON transactions(account_id);\nCREATE INDEX IF NOT EXISTS idx_transactions_date ON transactions(date);\nCREATE INDEX IF NOT EXISTS idx_transactions_series ON transactions(series_id);\nCREATE INDEX IF NOT EXISTS idx_monthly_budget_series ON monthly_budget(series_id, year, month);\nCREATE INDEX IF NOT EXISTS idx_project_items_project ON project_items(project_id);\n","numLines":85,"startLine":1,"totalLines":85}}}
