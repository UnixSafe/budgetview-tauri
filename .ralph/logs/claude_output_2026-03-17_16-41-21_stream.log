{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018awFXq4mwZmHh25pyN8p2v","type":"tool_result","content":"     1→// === Comptes ===\n     2→export interface Account {\n     3→\tid: number;\n     4→\tname: string;\n     5→\taccount_number: string | null;\n     6→\tbank_name: string | null;\n     7→\taccount_type: 'checking' | 'savings' | 'credit_card' | 'cash';\n     8→\tcurrency: string;\n     9→\tinitial_balance: number;\n    10→\tis_active: boolean;\n    11→\tcreated_at: string;\n    12→}\n    13→\n    14→export type AccountType = Account['account_type'];\n    15→\n    16→// === Budget Series (catégories) ===\n    17→export type BudgetArea = 'income' | 'recurring' | 'variable' | 'extras' | 'savings' | 'transfers';\n    18→\n    19→export interface BudgetSeries {\n    20→\tid: number;\n    21→\tname: string;\n    22→\tbudget_area: BudgetArea;\n    23→\ttarget_amount: number | null;\n    24→\tday_of_month: number | null;\n    25→\tis_active: boolean;\n    26→\tdescription: string | null;\n    27→}\n    28→\n    29→export interface SubSeries {\n    30→\tid: number;\n    31→\tseries_id: number;\n    32→\tname: string;\n    33→}\n    34→\n    35→// === Transactions ===\n    36→export interface Transaction {\n    37→\tid: number;\n    38→\taccount_id: number;\n    39→\tdate: string;\n    40→\tlabel: string;\n    41→\toriginal_label: string | null;\n    42→\tamount: number;\n    43→\tnote: string | null;\n    44→\tis_planned: boolean;\n    45→\tseries_id: number | null;\n    46→\tsub_series_id: number | null;\n    47→\timport_batch_id: number | null;\n    48→\tfitid: string | null;\n    49→\tcreated_at: string;\n    50→\t// Joined fields\n    51→\taccount_name?: string;\n    52→\tseries_name?: string;\n    53→}\n    54→\n    55→// === Budget mensuel ===\n    56→export interface MonthlyBudget {\n    57→\tid: number;\n    58→\tseries_id: number;\n    59→\tyear: number;\n    60→\tmonth: number;\n    61→\tplanned_amount: number;\n    62→}\n    63→\n    64→// === Budget view (agrégé) ===\n    65→export interface BudgetLineItem {\n    66→\tseries_id: number;\n    67→\tseries_name: string;\n    68→\tbudget_area: BudgetArea;\n    69→\tplanned_amount: number;\n    70→\tactual_amount: number;\n    71→}\n    72→\n    73→// === Import ===\n    74→export interface ImportBatch {\n    75→\tid: number;\n    76→\tfilename: string;\n    77→\tformat: 'ofx' | 'qif' | 'csv';\n    78→\taccount_id: number | null;\n    79→\ttransaction_count: number;\n    80→\timported_at: string;\n    81→}\n    82→\n    83→// === Catégorisation ===\n    84→export interface CategorizationRule {\n    85→\tid: number;\n    86→\tpattern: string;\n    87→\tseries_id: number;\n    88→\tsub_series_id: number | null;\n    89→\tmatch_count: number;\n    90→\tcreated_at: string;\n    91→}\n    92→\n    93→// === Projects ===\n    94→export interface Project {\n    95→\tid: number;\n    96→\tname: string;\n    97→\ttarget_amount: number | null;\n    98→\ttarget_date: string | null;\n    99→\taccount_id: number | null;\n   100→\tis_active: boolean;\n   101→}\n   102→\n   103→export interface ProjectItem {\n   104→\tid: number;\n   105→\tproject_id: number;\n   106→\tlabel: string;\n   107→\tplanned_amount: number;\n   108→\tmonth: number | null;\n   109→\tyear: number | null;\n   110→\tseries_id: number | null;\n   111→}\n   112→\n   113→// === Dashboard ===\n   114→export interface DashboardSummary {\n   115→\ttotal_balance: number;\n   116→\tmonth_income: number;\n   117→\tmonth_expenses: number;\n   118→\ttransaction_count: number;\n   119→}\n   120→"}]},"parent_tool_use_id":"toolu_01Wwqnwxr5nWEsa7JVeguQCH","session_id":"85d56d0a-e499-4451-8cdb-61d43ab7f486","uuid":"26b72982-1405-4588-b64a-2c619350add3","timestamp":"2026-03-17T15:43:30.336Z"}
