{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QXBPDofGNpVhyhT5P5vqom","type":"tool_result","content":"     1→use chrono::NaiveDate;\n     2→use serde::{Deserialize, Serialize};\n     3→use std::collections::HashMap;\n     4→\n     5→// === Types ===\n     6→\n     7→#[derive(Debug, Clone, Serialize, Deserialize)]\n     8→pub struct RawTransaction {\n     9→    pub date: String,\n    10→    pub label: String,\n    11→    pub original_label: String,\n    12→    pub amount: f64,\n    13→    pub note: Option<String>,\n    14→    pub fitid: Option<String>,\n    15→}\n    16→\n    17→#[derive(Debug, Clone, Serialize, Deserialize)]\n    18→pub struct ImportPreview {\n    19→    pub format: String,\n    20→    pub account_number: Option<String>,\n    21→    pub bank_id: Option<String>,\n    22→    pub transactions: Vec<RawTransaction>,\n    23→    pub duplicates: Vec<usize>,\n    24→    pub total_count: usize,\n    25→    pub new_count: usize,\n    26→}\n    27→\n    28→#[derive(Debug, Clone, Serialize, Deserialize)]\n    29→pub struct ImportResult {\n    30→    pub batch_id: i64,\n    31→    pub imported_count: usize,\n    32→    pub duplicates_skipped: usize,\n    33→    pub account_id: i64,\n    34→}\n    35→\n    36→#[derive(Debug, Clone, Serialize, Deserialize)]\n    37→pub struct CsvConfig {\n    38→    pub delimiter: char,\n    39→    pub date_column: usize,\n    40→    pub label_column: usize,\n    41→    pub amount_column: usize,\n    42→    pub debit_column: Option<usize>,\n    43→    pub credit_column: Option<usize>,\n    44→    pub date_format: String,\n    45→    pub skip_lines: usize,\n    46→    pub decimal_separator: char,\n    47→}\n    48→\n    49→impl Default for CsvConfig {\n    50→    fn default() -> Self {\n    51→        Self {\n    52→            delimiter: ';',\n    53→            date_column: 0,\n    54→            label_column: 1,\n    55→            amount_column: 2,\n    56→            debit_column: None,\n    57→            credit_column: None,\n    58→            date_format: \"%d/%m/%Y\".to_string(),\n    59→            skip_lines: 0,\n    60→            decimal_separator: ',',\n    61→        }\n    62→    }\n    63→}\n    64→\n    65→// === Format Detection ===\n    66→\n    67→pub fn detect_format(content: &str) -> &'static str {\n    68→    let upper = content.to_uppercase();\n    69→    if upper.contains(\"OFXHEADER\") || upper.contains(\"<OFX>\") {\n    70→        \"ofx\"\n    71→    } else if upper.contains(\"!TYPE:\") || upper.contains(\"!ACCOUNT\") {\n    72→        \"qif\"\n    73→    } else {\n    74→        \"csv\"\n    75→    }\n    76→}\n    77→\n    78→// === OFX Parser ===\n    79→// Handles both SGML (v1.x) and XML (v2.x) OFX formats\n    80→\n    81→pub fn parse_ofx(content: &str) -> Result<(Vec<RawTransaction>, Option<String>, Option<String>), String> {\n    82→    let mut transactions = Vec::new();\n    83→    let mut account_number: Option<String> = None;\n    84→    let mut bank_id: Option<String> = None;\n    85→\n    86→    // Extract account info\n    87→    if let Some(acctid) = extract_ofx_tag(content, \"ACCTID\") {\n    88→        account_number = Some(acctid.trim().to_string());\n    89→    }\n    90→    if let Some(bankid) = extract_ofx_tag(content, \"BANKID\") {\n    91→        bank_id = Some(bankid.trim().to_string());\n    92→    }\n    93→\n    94→    // Find all STMTTRN blocks\n    95→    let upper = content.to_uppercase();\n    96→    let mut search_from = 0;\n    97→\n    98→    loop {\n    99→        let start = match upper[search_from..].find(\"<STMTTRN>\") {\n   100→            Some(pos) => search_from + pos,\n   101→            None => break,\n   102→        };\n   103→        let end = match upper[start..].find(\"</STMTTRN>\") {\n   104→            Some(pos) => start + pos + \"</STMTTRN>\".len(),\n   105→            None => {\n   106→                // SGML style: no closing tag, find next STMTTRN or end of BANKTRANLIST\n   107→                match upper[start + 9..].find(\"<STMTTRN>\") {\n   108→                    Some(pos) => start + 9 + pos,\n   109→                    None => match upper[start..].find(\"</BANKTRANLIST>\") {\n   110→                        Some(pos) => start + pos,\n   111→                        None => content.len(),\n   112→                    },\n   113→                }\n   114→            }\n   115→        };\n   116→\n   117→        let block = &content[start..end];\n   118→\n   119→        let date_str = extract_ofx_tag(block, \"DTPOSTED\")\n   120→            .unwrap_or_default()\n   121→            .trim()\n   122→            .to_string();\n   123→        let amount_str = extract_ofx_tag(block, \"TRNAMT\")\n   124→            .unwrap_or_default()\n   125→            .trim()\n   126→            .to_string();\n   127→        let name = extract_ofx_tag(block, \"NAME\")\n   128→            .unwrap_or_default()\n   129→            .trim()\n   130→            .to_string();\n   131→        let memo = extract_ofx_tag(block, \"MEMO\").map(|s| s.trim().to_string());\n   132→        let fitid = extract_ofx_tag(block, \"FITID\").map(|s| s.trim().to_string());\n   133→\n   134→        // Parse date: YYYYMMDD or YYYYMMDDHHMMSS\n   135→        let date = parse_ofx_date(&date_str).unwrap_or_else(|| date_str.clone());\n   136→\n   137→        // Parse amount\n   138→        let amount: f64 = amount_str\n   139→            .replace(',', \".\")\n   140→            .parse()\n   141→            .unwrap_or(0.0);\n   142→\n   143→        let label = clean_label(&name);\n   144→\n   145→        if !label.is_empty() || amount != 0.0 {\n   146→            transactions.push(RawTransaction {\n   147→                date,\n   148→                label: label.clone(),\n   149→                original_label: name,\n   150→                amount,\n   151→                note: memo,\n   152→                fitid,\n   153→            });\n   154→        }\n   155→\n   156→        search_from = end;\n   157→    }\n   158→\n   159→    Ok((transactions, account_number, bank_id))\n   160→}\n   161→\n   162→fn extract_ofx_tag(content: &str, tag: &str) -> Option<String> {\n   163→    let upper_content = content.to_uppercase();\n   164→    let open_tag = format!(\"<{}>\", tag.to_uppercase());\n   165→    let close_tag = format!(\"</{}>\", tag.to_uppercase());\n   166→\n   167→    if let Some(start) = upper_content.find(&open_tag) {\n   168→        let value_start = start + open_tag.len();\n   169→        // Check for closing tag\n   170→        let value_end = if let Some(close_pos) = upper_content[value_start..].find(&close_tag) {\n   171→            value_start + close_pos\n   172→        } else {\n   173→            // SGML: value ends at next < or newline\n   174→            let remaining = &content[value_start..];\n   175→            let end = remaining\n   176→                .find('<')\n   177→                .unwrap_or_else(|| remaining.find('\\n').unwrap_or(remaining.len()));\n   178→            value_start + end\n   179→        };\n   180→        Some(content[value_start..value_end].to_string())\n   181→    } else {\n   182→        None\n   183→    }\n   184→}\n   185→\n   186→fn parse_ofx_date(s: &str) -> Option<String> {\n   187→    if s.len() >= 8 {\n   188→        let year = &s[0..4];\n   189→        let month = &s[4..6];\n   190→        let day = &s[6..8];\n   191→        // Validate\n   192→        if let Ok(d) = NaiveDate::parse_from_str(&format!(\"{}-{}-{}\", year, month, day), \"%Y-%m-%d\") {\n   193→            return Some(d.format(\"%Y-%m-%d\").to_string());\n   194→        }\n   195→    }\n   196→    None\n   197→}\n   198→\n   199→// === QIF Parser ===\n   200→\n   201→pub fn parse_qif(content: &str) -> Result<Vec<RawTransaction>, String> {\n   202→    let mut transactions = Vec::new();\n   203→    let mut current_date = String::new();\n   204→    let mut current_amount = 0.0;\n   205→    let mut current_label = String::new();\n   206→    let mut current_memo: Option<String> = None;\n   207→    let mut in_transaction = false;\n   208→\n   209→    for line in content.lines() {\n   210→        let line = line.trim();\n   211→        if line.is_empty() {\n   212→            continue;\n   213→        }\n   214→\n   215→        // Skip header lines\n   216→        if line.starts_with('!') {\n   217→            continue;\n   218→        }\n   219→\n   220→        // Record separator\n   221→        if line == \"^\" {\n   222→            if in_transaction && !current_label.is_empty() {\n   223→                transactions.push(RawTransaction {\n   224→                    date: current_date.clone(),\n   225→                    label: clean_label(&current_label),\n   226→                    original_label: current_label.clone(),\n   227→                    amount: current_amount,\n   228→                    note: current_memo.clone(),\n   229→                    fitid: None,\n   230→                });\n   231→            }\n   232→            // Reset\n   233→            current_date.clear();\n   234→            current_amount = 0.0;\n   235→            current_label.clear();\n   236→            current_memo = None;\n   237→            in_transaction = false;\n   238→            continue;\n   239→        }\n   240→\n   241→        let (code, value) = (line.chars().next().unwrap_or(' '), &line[1..]);\n   242→\n   243→        match code {\n   244→            'D' => {\n   245→                current_date = parse_qif_date(value.trim());\n   246→                in_transaction = true;\n   247→            }\n   248→            'T' | 'U' => {\n   249→                let cleaned = value.trim().replace(',', \".\").replace(' ', \"\");\n   250→                current_amount = cleaned.parse().unwrap_or(0.0);\n   251→                in_transaction = true;\n   252→            }\n   253→            'P' => {\n   254→                current_label = value.trim().to_string();\n   255→                in_transaction = true;\n   256→            }\n   257→            'M' => {\n   258→                current_memo = Some(value.trim().to_string());\n   259→            }\n   260→            'N' | 'L' | 'C' | 'A' => {\n   261→                // N=check number, L=category, C=cleared, A=address — skip\n   262→                in_transaction = true;\n   263→            }\n   264→            _ => {}\n   265→        }\n   266→    }\n   267→\n   268→    // Handle last transaction if no trailing ^\n   269→    if in_transaction && !current_label.is_empty() {\n   270→        transactions.push(RawTransaction {\n   271→            date: current_date,\n   272→            label: clean_label(&current_label),\n   273→            original_label: current_label,\n   274→            amount: current_amount,\n   275→            note: current_memo,\n   276→            fitid: None,\n   277→        });\n   278→    }\n   279→\n   280→    Ok(transactions)\n   281→}\n   282→\n   283→fn parse_qif_date(s: &str) -> String {\n   284→    // Try common QIF date formats\n   285→    // French: DD/MM/YYYY or DD/MM/YY\n   286→    // US: MM/DD/YYYY or M/D/YY\n   287→    // Also: DD-MM-YYYY, DD.MM.YYYY\n   288→\n   289→    let cleaned = s.replace(['-', '.'], \"/\");\n   290→    let parts: Vec<&str> = cleaned.split('/').collect();\n   291→\n   292→    if parts.len() == 3 {\n   293→        let a: u32 = parts[0].parse().unwrap_or(0);\n   294→        let b: u32 = parts[1].parse().unwrap_or(0);\n   295→        let mut c: u32 = parts[2].trim_matches('\\'').parse().unwrap_or(0);\n   296→\n   297→        // Handle 2-digit year\n   298→        if c < 100 {\n   299→            c += if c > 70 { 1900 } else { 2000 };\n   300→        }\n   301→\n   302→        // Determine if DD/MM/YYYY (French) or MM/DD/YYYY (US)\n   303→        // Heuristic: if first number > 12, it's the day (French format)\n   304→        let (day, month, year) = if a > 12 {\n   305→            (a, b, c)\n   306→        } else if b > 12 {\n   307→            (b, a, c)\n   308→        } else {\n   309→            // Ambiguous — assume French (DD/MM/YYYY)\n   310→            (a, b, c)\n   311→        };\n   312→\n   313→        if let Some(d) = NaiveDate::from_ymd_opt(year as i32, month, day) {\n   314→            return d.format(\"%Y-%m-%d\").to_string();\n   315→        }\n   316→    }\n   317→\n   318→    s.to_string()\n   319→}\n   320→\n   321→// === CSV Parser ===\n   322→\n   323→pub fn parse_csv(content: &str, config: &CsvConfig) -> Result<Vec<RawTransaction>, String> {\n   324→    let mut transactions = Vec::new();\n   325→\n   326→    let delimiter = config.delimiter as u8;\n   327→    let mut reader = csv::ReaderBuilder::new()\n   328→        .delimiter(delimiter)\n   329→        .flexible(true)\n   330→        .has_headers(true)\n   331→        .from_reader(content.as_bytes());\n   332→\n   333→    // Skip extra header lines if configured\n   334→    // (csv crate already skips one header line)\n   335→\n   336→    for result in reader.records() {\n   337→        let record = result.map_err(|e| format!(\"Erreur CSV ligne: {}\", e))?;\n   338→\n   339→        let date_str = record.get(config.date_column).unwrap_or(\"\").trim();\n   340→        let label_str = record.get(config.label_column).unwrap_or(\"\").trim();\n   341→\n   342→        if date_str.is_empty() || label_str.is_empty() {\n   343→            continue;\n   344→        }\n   345→\n   346→        let amount = if let (Some(debit_col), Some(credit_col)) = (config.debit_column, config.credit_column) {\n   347→            // Separate debit/credit columns\n   348→            let debit = parse_french_number(record.get(debit_col).unwrap_or(\"\"), config.decimal_separator);\n   349→            let credit = parse_french_number(record.get(credit_col).unwrap_or(\"\"), config.decimal_separator);\n   350→            credit - debit\n   351→        } else {\n   352→            parse_french_number(record.get(config.amount_column).unwrap_or(\"\"), config.decimal_separator)\n   353→        };\n   354→\n   355→        // Parse date\n   356→        let date = parse_csv_date(date_str, &config.date_format);\n   357→\n   358→        let label = clean_label(label_str);\n   359→\n   360→        transactions.push(RawTransaction {\n   361→            date,\n   362→            label: label.clone(),\n   363→            original_label: label_str.to_string(),\n   364→            amount,\n   365→            note: None,\n   366→            fitid: None,\n   367→        });\n   368→    }\n   369→\n   370→    Ok(transactions)\n   371→}\n   372→\n   373→/// Auto-detect CSV configuration from content\n   374→pub fn detect_csv_config(content: &str) -> CsvConfig {\n   375→    let mut config = CsvConfig::default();\n   376→\n   377→    // Detect delimiter\n   378→    let first_lines: Vec<&str> = content.lines().take(5).collect();\n   379→    if let Some(header) = first_lines.first() {\n   380→        let semicolons = header.matches(';').count();\n   381→        let commas = header.matches(',').count();\n   382→        let tabs = header.matches('\\t').count();\n   383→\n   384→        if tabs > semicolons && tabs > commas {\n   385→            config.delimiter = '\\t';\n   386→        } else if commas > semicolons {\n   387→            config.delimiter = ',';\n   388→            config.decimal_separator = '.';\n   389→        }\n   390→        // default is ';' with ',' decimal (French)\n   391→    }\n   392→\n   393→    // Try to detect columns from header\n   394→    if let Some(header) = first_lines.first() {\n   395→        let cols: Vec<&str> = header\n   396→            .split(config.delimiter)\n   397→            .map(|s| s.trim().trim_matches('\"').to_uppercase())\n   398→            .collect();\n   399→\n   400→        let col_map: HashMap<usize, &str> = cols.iter().enumerate().map(|(i, s)| (i, s.as_str())).collect();\n   401→\n   402→        for (i, name) in &col_map {\n   403→            if name.contains(\"DATE\") && !name.contains(\"VALEUR\") && !name.contains(\"VALUE\") {\n   404→                config.date_column = *i;\n   405→            } else if name.contains(\"LIBEL\") || name.contains(\"LABEL\") || name.contains(\"DESCR\") || *name == \"LIBELLÉ\" {\n   406→                config.label_column = *i;\n   407→            } else if name.contains(\"MONTANT\") || name.contains(\"AMOUNT\") {\n   408→                config.amount_column = *i;\n   409→            } else if name.contains(\"DEBIT\") || name.contains(\"DÉBIT\") {\n   410→                config.debit_column = Some(*i);\n   411→            } else if name.contains(\"CREDIT\") || name.contains(\"CRÉDIT\") {\n   412→                config.credit_column = Some(*i);\n   413→            }\n   414→        }\n   415→    }\n   416→\n   417→    // Detect date format from first data line\n   418→    if let Some(data_line) = first_lines.get(1) {\n   419→        let cols: Vec<&str> = data_line.split(config.delimiter).collect();\n   420→        if let Some(date_str) = cols.get(config.date_column) {\n   421→            let date_str = date_str.trim().trim_matches('\"');\n   422→            if date_str.contains('/') {\n   423→                let parts: Vec<&str> = date_str.split('/').collect();\n   424→                if parts.len() == 3 {\n   425→                    if parts[2].len() == 4 && parts[0].len() <= 2 {\n   426→                        config.date_format = \"%d/%m/%Y\".to_string();\n   427→                    } else if parts[0].len() == 4 {\n   428→                        config.date_format = \"%Y/%m/%d\".to_string();\n   429→                    }\n   430→                }\n   431→            } else if date_str.contains('-') {\n   432→                config.date_format = \"%Y-%m-%d\".to_string();\n   433→            }\n   434→        }\n   435→    }\n   436→\n   437→    config\n   438→}\n   439→\n   440→fn parse_french_number(s: &str, decimal_sep: char) -> f64 {\n   441→    let cleaned = s\n   442→        .trim()\n   443→        .trim_matches('\"')\n   444→        .replace('\\u{a0}', \"\") // non-breaking space\n   445→        .replace(' ', \"\");\n   446→\n   447→    if cleaned.is_empty() {\n   448→        return 0.0;\n   449→    }\n   450→\n   451→    let normalized = if decimal_sep == ',' {\n   452→        // French: 1.234,56 or 1234,56\n   453→        cleaned.replace('.', \"\").replace(',', \".\")\n   454→    } else {\n   455→        // English: 1,234.56 or 1234.56\n   456→        cleaned.replace(',', \"\")\n   457→    };\n   458→\n   459→    normalized.parse().unwrap_or(0.0)\n   460→}\n   461→\n   462→fn parse_csv_date(s: &str, format: &str) -> String {\n   463→    let cleaned = s.trim().trim_matches('\"');\n   464→    if let Ok(d) = NaiveDate::parse_from_str(cleaned, format) {\n   465→        d.format(\"%Y-%m-%d\").to_string()\n   466→    } else {\n   467→        // Fallback: try common formats\n   468→        for fmt in &[\"%d/%m/%Y\", \"%Y-%m-%d\", \"%d-%m-%Y\", \"%Y/%m/%d\", \"%d.%m.%Y\"] {\n   469→            if let Ok(d) = NaiveDate::parse_from_str(cleaned, fmt) {\n   470→                return d.format(\"%Y-%m-%d\").to_string();\n   471→            }\n   472→        }\n   473→        cleaned.to_string()\n   474→    }\n   475→}\n   476→\n   477→// === Helpers ===\n   478→\n   479→fn clean_label(s: &str) -> String {\n   480→    // Normalize whitespace, trim, title-case-ish\n   481→    let cleaned: String = s\n   482→        .split_whitespace()\n   483→        .collect::<Vec<_>>()\n   484→        .join(\" \");\n   485→    cleaned.trim().to_string()\n   486→}\n   487→\n   488→// === Dedup ===\n   489→\n   490→/// Check which transaction indices are duplicates based on FITID or (date, amount, label) matching\n   491→pub fn find_duplicate_indices(\n   492→    new_txs: &[RawTransaction],\n   493→    existing_fitids: &[String],\n   494→    existing_hashes: &[(String, f64, String)], // (date, amount, label)\n   495→) -> Vec<usize> {\n   496→    let fitid_set: std::collections::HashSet<&str> = existing_fitids.iter().map(|s| s.as_str()).collect();\n   497→    let hash_set: std::collections::HashSet<String> = existing_hashes\n   498→        .iter()\n   499→        .map(|(d, a, l)| format!(\"{}|{:.2}|{}\", d, a, l.to_uppercase()))\n   500→        .collect();\n   501→\n   502→    let mut duplicates = Vec::new();\n   503→    for (i, tx) in new_txs.iter().enumerate() {\n   504→        // Check FITID first (most reliable)\n   505→        if let Some(ref fitid) = tx.fitid {\n   506→            if fitid_set.contains(fitid.as_str()) {\n   507→                duplicates.push(i);\n   508→                continue;\n   509→            }\n   510→        }\n   511→        // Fallback: fuzzy match on date + amount + normalized label\n   512→        let hash = format!(\"{}|{:.2}|{}\", tx.date, tx.amount, tx.label.to_uppercase());\n   513→        if hash_set.contains(&hash) {\n   514→            duplicates.push(i);\n   515→        }\n   516→    }\n   517→    duplicates\n   518→}\n   519→\n   520→/// Read file with encoding detection (handles ISO-8859-1 common in French bank exports)\n   521→pub fn read_file_with_encoding(path: &str) -> Result<String, String> {\n   522→    let bytes = std::fs::read(path).map_err(|e| format!(\"Impossible de lire le fichier: {}\", e))?;\n   523→\n   524→    // Try UTF-8 first\n   525→    if let Ok(s) = String::from_utf8(bytes.clone()) {\n   526→        return Ok(s);\n   527→    }\n   528→\n   529→    // Fallback: try ISO-8859-1 (Latin-1), common in French bank exports\n   530→    let (decoded, _, had_errors) = encoding_rs::WINDOWS_1252.decode(&bytes);\n   531→    if !had_errors {\n   532→        return Ok(decoded.into_owned());\n   533→    }\n   534→\n   535→    // Last resort: lossy UTF-8\n   536→    Ok(String::from_utf8_lossy(&bytes).into_owned())\n   537→}\n   538→"}]},"parent_tool_use_id":null,"session_id":"85d56d0a-e499-4451-8cdb-61d43ab7f486","uuid":"31a49f60-6cb8-400e-ad5f-c9a7c516a524","timestamp":"2026-03-17T15:49:59.771Z","tool_use_result":{"type":"text","file":{"filePath":"/home/jeremy/Documents/budgetview-tauri/src-tauri/src/import.rs","content":"use chrono::NaiveDate;\nuse serde::{Deserialize, Serialize};\nuse std::collections::HashMap;\n\n// === Types ===\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct RawTransaction {\n    pub date: String,\n    pub label: String,\n    pub original_label: String,\n    pub amount: f64,\n    pub note: Option<String>,\n    pub fitid: Option<String>,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct ImportPreview {\n    pub format: String,\n    pub account_number: Option<String>,\n    pub bank_id: Option<String>,\n    pub transactions: Vec<RawTransaction>,\n    pub duplicates: Vec<usize>,\n    pub total_count: usize,\n    pub new_count: usize,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct ImportResult {\n    pub batch_id: i64,\n    pub imported_count: usize,\n    pub duplicates_skipped: usize,\n    pub account_id: i64,\n}\n\n#[derive(Debug, Clone, Serialize, Deserialize)]\npub struct CsvConfig {\n    pub delimiter: char,\n    pub date_column: usize,\n    pub label_column: usize,\n    pub amount_column: usize,\n    pub debit_column: Option<usize>,\n    pub credit_column: Option<usize>,\n    pub date_format: String,\n    pub skip_lines: usize,\n    pub decimal_separator: char,\n}\n\nimpl Default for CsvConfig {\n    fn default() -> Self {\n        Self {\n            delimiter: ';',\n            date_column: 0,\n            label_column: 1,\n            amount_column: 2,\n            debit_column: None,\n            credit_column: None,\n            date_format: \"%d/%m/%Y\".to_string(),\n            skip_lines: 0,\n            decimal_separator: ',',\n        }\n    }\n}\n\n// === Format Detection ===\n\npub fn detect_format(content: &str) -> &'static str {\n    let upper = content.to_uppercase();\n    if upper.contains(\"OFXHEADER\") || upper.contains(\"<OFX>\") {\n        \"ofx\"\n    } else if upper.contains(\"!TYPE:\") || upper.contains(\"!ACCOUNT\") {\n        \"qif\"\n    } else {\n        \"csv\"\n    }\n}\n\n// === OFX Parser ===\n// Handles both SGML (v1.x) and XML (v2.x) OFX formats\n\npub fn parse_ofx(content: &str) -> Result<(Vec<RawTransaction>, Option<String>, Option<String>), String> {\n    let mut transactions = Vec::new();\n    let mut account_number: Option<String> = None;\n    let mut bank_id: Option<String> = None;\n\n    // Extract account info\n    if let Some(acctid) = extract_ofx_tag(content, \"ACCTID\") {\n        account_number = Some(acctid.trim().to_string());\n    }\n    if let Some(bankid) = extract_ofx_tag(content, \"BANKID\") {\n        bank_id = Some(bankid.trim().to_string());\n    }\n\n    // Find all STMTTRN blocks\n    let upper = content.to_uppercase();\n    let mut search_from = 0;\n\n    loop {\n        let start = match upper[search_from..].find(\"<STMTTRN>\") {\n            Some(pos) => search_from + pos,\n            None => break,\n        };\n        let end = match upper[start..].find(\"</STMTTRN>\") {\n            Some(pos) => start + pos + \"</STMTTRN>\".len(),\n            None => {\n                // SGML style: no closing tag, find next STMTTRN or end of BANKTRANLIST\n                match upper[start + 9..].find(\"<STMTTRN>\") {\n                    Some(pos) => start + 9 + pos,\n                    None => match upper[start..].find(\"</BANKTRANLIST>\") {\n                        Some(pos) => start + pos,\n                        None => content.len(),\n                    },\n                }\n            }\n        };\n\n        let block = &content[start..end];\n\n        let date_str = extract_ofx_tag(block, \"DTPOSTED\")\n            .unwrap_or_default()\n            .trim()\n            .to_string();\n        let amount_str = extract_ofx_tag(block, \"TRNAMT\")\n            .unwrap_or_default()\n            .trim()\n            .to_string();\n        let name = extract_ofx_tag(block, \"NAME\")\n            .unwrap_or_default()\n            .trim()\n            .to_string();\n        let memo = extract_ofx_tag(block, \"MEMO\").map(|s| s.trim().to_string());\n        let fitid = extract_ofx_tag(block, \"FITID\").map(|s| s.trim().to_string());\n\n        // Parse date: YYYYMMDD or YYYYMMDDHHMMSS\n        let date = parse_ofx_date(&date_str).unwrap_or_else(|| date_str.clone());\n\n        // Parse amount\n        let amount: f64 = amount_str\n            .replace(',', \".\")\n            .parse()\n            .unwrap_or(0.0);\n\n        let label = clean_label(&name);\n\n        if !label.is_empty() || amount != 0.0 {\n            transactions.push(RawTransaction {\n                date,\n                label: label.clone(),\n                original_label: name,\n                amount,\n                note: memo,\n                fitid,\n            });\n        }\n\n        search_from = end;\n    }\n\n    Ok((transactions, account_number, bank_id))\n}\n\nfn extract_ofx_tag(content: &str, tag: &str) -> Option<String> {\n    let upper_content = content.to_uppercase();\n    let open_tag = format!(\"<{}>\", tag.to_uppercase());\n    let close_tag = format!(\"</{}>\", tag.to_uppercase());\n\n    if let Some(start) = upper_content.find(&open_tag) {\n        let value_start = start + open_tag.len();\n        // Check for closing tag\n        let value_end = if let Some(close_pos) = upper_content[value_start..].find(&close_tag) {\n            value_start + close_pos\n        } else {\n            // SGML: value ends at next < or newline\n            let remaining = &content[value_start..];\n            let end = remaining\n                .find('<')\n                .unwrap_or_else(|| remaining.find('\\n').unwrap_or(remaining.len()));\n            value_start + end\n        };\n        Some(content[value_start..value_end].to_string())\n    } else {\n        None\n    }\n}\n\nfn parse_ofx_date(s: &str) -> Option<String> {\n    if s.len() >= 8 {\n        let year = &s[0..4];\n        let month = &s[4..6];\n        let day = &s[6..8];\n        // Validate\n        if let Ok(d) = NaiveDate::parse_from_str(&format!(\"{}-{}-{}\", year, month, day), \"%Y-%m-%d\") {\n            return Some(d.format(\"%Y-%m-%d\").to_string());\n        }\n    }\n    None\n}\n\n// === QIF Parser ===\n\npub fn parse_qif(content: &str) -> Result<Vec<RawTransaction>, String> {\n    let mut transactions = Vec::new();\n    let mut current_date = String::new();\n    let mut current_amount = 0.0;\n    let mut current_label = String::new();\n    let mut current_memo: Option<String> = None;\n    let mut in_transaction = false;\n\n    for line in content.lines() {\n        let line = line.trim();\n        if line.is_empty() {\n            continue;\n        }\n\n        // Skip header lines\n        if line.starts_with('!') {\n            continue;\n        }\n\n        // Record separator\n        if line == \"^\" {\n            if in_transaction && !current_label.is_empty() {\n                transactions.push(RawTransaction {\n                    date: current_date.clone(),\n                    label: clean_label(&current_label),\n                    original_label: current_label.clone(),\n                    amount: current_amount,\n                    note: current_memo.clone(),\n                    fitid: None,\n                });\n            }\n            // Reset\n            current_date.clear();\n            current_amount = 0.0;\n            current_label.clear();\n            current_memo = None;\n            in_transaction = false;\n            continue;\n        }\n\n        let (code, value) = (line.chars().next().unwrap_or(' '), &line[1..]);\n\n        match code {\n            'D' => {\n                current_date = parse_qif_date(value.trim());\n                in_transaction = true;\n            }\n            'T' | 'U' => {\n                let cleaned = value.trim().replace(',', \".\").replace(' ', \"\");\n                current_amount = cleaned.parse().unwrap_or(0.0);\n                in_transaction = true;\n            }\n            'P' => {\n                current_label = value.trim().to_string();\n                in_transaction = true;\n            }\n            'M' => {\n                current_memo = Some(value.trim().to_string());\n            }\n            'N' | 'L' | 'C' | 'A' => {\n                // N=check number, L=category, C=cleared, A=address — skip\n                in_transaction = true;\n            }\n            _ => {}\n        }\n    }\n\n    // Handle last transaction if no trailing ^\n    if in_transaction && !current_label.is_empty() {\n        transactions.push(RawTransaction {\n            date: current_date,\n            label: clean_label(&current_label),\n            original_label: current_label,\n            amount: current_amount,\n            note: current_memo,\n            fitid: None,\n        });\n    }\n\n    Ok(transactions)\n}\n\nfn parse_qif_date(s: &str) -> String {\n    // Try common QIF date formats\n    // French: DD/MM/YYYY or DD/MM/YY\n    // US: MM/DD/YYYY or M/D/YY\n    // Also: DD-MM-YYYY, DD.MM.YYYY\n\n    let cleaned = s.replace(['-', '.'], \"/\");\n    let parts: Vec<&str> = cleaned.split('/').collect();\n\n    if parts.len() == 3 {\n        let a: u32 = parts[0].parse().unwrap_or(0);\n        let b: u32 = parts[1].parse().unwrap_or(0);\n        let mut c: u32 = parts[2].trim_matches('\\'').parse().unwrap_or(0);\n\n        // Handle 2-digit year\n        if c < 100 {\n            c += if c > 70 { 1900 } else { 2000 };\n        }\n\n        // Determine if DD/MM/YYYY (French) or MM/DD/YYYY (US)\n        // Heuristic: if first number > 12, it's the day (French format)\n        let (day, month, year) = if a > 12 {\n            (a, b, c)\n        } else if b > 12 {\n            (b, a, c)\n        } else {\n            // Ambiguous — assume French (DD/MM/YYYY)\n            (a, b, c)\n        };\n\n        if let Some(d) = NaiveDate::from_ymd_opt(year as i32, month, day) {\n            return d.format(\"%Y-%m-%d\").to_string();\n        }\n    }\n\n    s.to_string()\n}\n\n// === CSV Parser ===\n\npub fn parse_csv(content: &str, config: &CsvConfig) -> Result<Vec<RawTransaction>, String> {\n    let mut transactions = Vec::new();\n\n    let delimiter = config.delimiter as u8;\n    let mut reader = csv::ReaderBuilder::new()\n        .delimiter(delimiter)\n        .flexible(true)\n        .has_headers(true)\n        .from_reader(content.as_bytes());\n\n    // Skip extra header lines if configured\n    // (csv crate already skips one header line)\n\n    for result in reader.records() {\n        let record = result.map_err(|e| format!(\"Erreur CSV ligne: {}\", e))?;\n\n        let date_str = record.get(config.date_column).unwrap_or(\"\").trim();\n        let label_str = record.get(config.label_column).unwrap_or(\"\").trim();\n\n        if date_str.is_empty() || label_str.is_empty() {\n            continue;\n        }\n\n        let amount = if let (Some(debit_col), Some(credit_col)) = (config.debit_column, config.credit_column) {\n            // Separate debit/credit columns\n            let debit = parse_french_number(record.get(debit_col).unwrap_or(\"\"), config.decimal_separator);\n            let credit = parse_french_number(record.get(credit_col).unwrap_or(\"\"), config.decimal_separator);\n            credit - debit\n        } else {\n            parse_french_number(record.get(config.amount_column).unwrap_or(\"\"), config.decimal_separator)\n        };\n\n        // Parse date\n        let date = parse_csv_date(date_str, &config.date_format);\n\n        let label = clean_label(label_str);\n\n        transactions.push(RawTransaction {\n            date,\n            label: label.clone(),\n            original_label: label_str.to_string(),\n            amount,\n            note: None,\n            fitid: None,\n        });\n    }\n\n    Ok(transactions)\n}\n\n/// Auto-detect CSV configuration from content\npub fn detect_csv_config(content: &str) -> CsvConfig {\n    let mut config = CsvConfig::default();\n\n    // Detect delimiter\n    let first_lines: Vec<&str> = content.lines().take(5).collect();\n    if let Some(header) = first_lines.first() {\n        let semicolons = header.matches(';').count();\n        let commas = header.matches(',').count();\n        let tabs = header.matches('\\t').count();\n\n        if tabs > semicolons && tabs > commas {\n            config.delimiter = '\\t';\n        } else if commas > semicolons {\n            config.delimiter = ',';\n            config.decimal_separator = '.';\n        }\n        // default is ';' with ',' decimal (French)\n    }\n\n    // Try to detect columns from header\n    if let Some(header) = first_lines.first() {\n        let cols: Vec<&str> = header\n            .split(config.delimiter)\n            .map(|s| s.trim().trim_matches('\"').to_uppercase())\n            .collect();\n\n        let col_map: HashMap<usize, &str> = cols.iter().enumerate().map(|(i, s)| (i, s.as_str())).collect();\n\n        for (i, name) in &col_map {\n            if name.contains(\"DATE\") && !name.contains(\"VALEUR\") && !name.contains(\"VALUE\") {\n                config.date_column = *i;\n            } else if name.contains(\"LIBEL\") || name.contains(\"LABEL\") || name.contains(\"DESCR\") || *name == \"LIBELLÉ\" {\n                config.label_column = *i;\n            } else if name.contains(\"MONTANT\") || name.contains(\"AMOUNT\") {\n                config.amount_column = *i;\n            } else if name.contains(\"DEBIT\") || name.contains(\"DÉBIT\") {\n                config.debit_column = Some(*i);\n            } else if name.contains(\"CREDIT\") || name.contains(\"CRÉDIT\") {\n                config.credit_column = Some(*i);\n            }\n        }\n    }\n\n    // Detect date format from first data line\n    if let Some(data_line) = first_lines.get(1) {\n        let cols: Vec<&str> = data_line.split(config.delimiter).collect();\n        if let Some(date_str) = cols.get(config.date_column) {\n            let date_str = date_str.trim().trim_matches('\"');\n            if date_str.contains('/') {\n                let parts: Vec<&str> = date_str.split('/').collect();\n                if parts.len() == 3 {\n                    if parts[2].len() == 4 && parts[0].len() <= 2 {\n                        config.date_format = \"%d/%m/%Y\".to_string();\n                    } else if parts[0].len() == 4 {\n                        config.date_format = \"%Y/%m/%d\".to_string();\n                    }\n                }\n            } else if date_str.contains('-') {\n                config.date_format = \"%Y-%m-%d\".to_string();\n            }\n        }\n    }\n\n    config\n}\n\nfn parse_french_number(s: &str, decimal_sep: char) -> f64 {\n    let cleaned = s\n        .trim()\n        .trim_matches('\"')\n        .replace('\\u{a0}', \"\") // non-breaking space\n        .replace(' ', \"\");\n\n    if cleaned.is_empty() {\n        return 0.0;\n    }\n\n    let normalized = if decimal_sep == ',' {\n        // French: 1.234,56 or 1234,56\n        cleaned.replace('.', \"\").replace(',', \".\")\n    } else {\n        // English: 1,234.56 or 1234.56\n        cleaned.replace(',', \"\")\n    };\n\n    normalized.parse().unwrap_or(0.0)\n}\n\nfn parse_csv_date(s: &str, format: &str) -> String {\n    let cleaned = s.trim().trim_matches('\"');\n    if let Ok(d) = NaiveDate::parse_from_str(cleaned, format) {\n        d.format(\"%Y-%m-%d\").to_string()\n    } else {\n        // Fallback: try common formats\n        for fmt in &[\"%d/%m/%Y\", \"%Y-%m-%d\", \"%d-%m-%Y\", \"%Y/%m/%d\", \"%d.%m.%Y\"] {\n            if let Ok(d) = NaiveDate::parse_from_str(cleaned, fmt) {\n                return d.format(\"%Y-%m-%d\").to_string();\n            }\n        }\n        cleaned.to_string()\n    }\n}\n\n// === Helpers ===\n\nfn clean_label(s: &str) -> String {\n    // Normalize whitespace, trim, title-case-ish\n    let cleaned: String = s\n        .split_whitespace()\n        .collect::<Vec<_>>()\n        .join(\" \");\n    cleaned.trim().to_string()\n}\n\n// === Dedup ===\n\n/// Check which transaction indices are duplicates based on FITID or (date, amount, label) matching\npub fn find_duplicate_indices(\n    new_txs: &[RawTransaction],\n    existing_fitids: &[String],\n    existing_hashes: &[(String, f64, String)], // (date, amount, label)\n) -> Vec<usize> {\n    let fitid_set: std::collections::HashSet<&str> = existing_fitids.iter().map(|s| s.as_str()).collect();\n    let hash_set: std::collections::HashSet<String> = existing_hashes\n        .iter()\n        .map(|(d, a, l)| format!(\"{}|{:.2}|{}\", d, a, l.to_uppercase()))\n        .collect();\n\n    let mut duplicates = Vec::new();\n    for (i, tx) in new_txs.iter().enumerate() {\n        // Check FITID first (most reliable)\n        if let Some(ref fitid) = tx.fitid {\n            if fitid_set.contains(fitid.as_str()) {\n                duplicates.push(i);\n                continue;\n            }\n        }\n        // Fallback: fuzzy match on date + amount + normalized label\n        let hash = format!(\"{}|{:.2}|{}\", tx.date, tx.amount, tx.label.to_uppercase());\n        if hash_set.contains(&hash) {\n            duplicates.push(i);\n        }\n    }\n    duplicates\n}\n\n/// Read file with encoding detection (handles ISO-8859-1 common in French bank exports)\npub fn read_file_with_encoding(path: &str) -> Result<String, String> {\n    let bytes = std::fs::read(path).map_err(|e| format!(\"Impossible de lire le fichier: {}\", e))?;\n\n    // Try UTF-8 first\n    if let Ok(s) = String::from_utf8(bytes.clone()) {\n        return Ok(s);\n    }\n\n    // Fallback: try ISO-8859-1 (Latin-1), common in French bank exports\n    let (decoded, _, had_errors) = encoding_rs::WINDOWS_1252.decode(&bytes);\n    if !had_errors {\n        return Ok(decoded.into_owned());\n    }\n\n    // Last resort: lossy UTF-8\n    Ok(String::from_utf8_lossy(&bytes).into_owned())\n}\n","numLines":538,"startLine":1,"totalLines":538}}}
