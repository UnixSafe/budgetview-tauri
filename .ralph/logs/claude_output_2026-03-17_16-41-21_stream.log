{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W64czf6r4BXqyJ5DWyJ48p","type":"tool_result","content":"     1→use serde::{Deserialize, Serialize};\n     2→use tauri::command;\n     3→use tauri_plugin_sql::{DbInstances, DbPool};\n     4→\n     5→use crate::import::{\n     6→    self, CsvConfig, ImportPreview, ImportResult, RawTransaction,\n     7→};\n     8→\n     9→#[command]\n    10→pub fn greet(name: &str) -> String {\n    11→    format!(\"Bienvenue dans BudgetView, {} !\", name)\n    12→}\n    13→\n    14→/// Parse a file and return a preview of transactions to import\n    15→#[command]\n    16→pub async fn import_preview(\n    17→    file_path: String,\n    18→    csv_config: Option<CsvConfig>,\n    19→    db: tauri::State<'_, DbInstances>,\n    20→) -> Result<ImportPreview, String> {\n    21→    // Read file with encoding detection\n    22→    let content = import::read_file_with_encoding(&file_path)?;\n    23→    let format = import::detect_format(&content);\n    24→\n    25→    let (transactions, account_number, bank_id) = match format {\n    26→        \"ofx\" => import::parse_ofx(&content)?,\n    27→        \"qif\" => {\n    28→            let txs = import::parse_qif(&content)?;\n    29→            (txs, None, None)\n    30→        }\n    31→        \"csv\" => {\n    32→            let config = csv_config.unwrap_or_else(|| import::detect_csv_config(&content));\n    33→            let txs = import::parse_csv(&content, &config)?;\n    34→            (txs, None, None)\n    35→        }\n    36→        _ => return Err(\"Format de fichier non reconnu\".to_string()),\n    37→    };\n    38→\n    39→    // Get existing transactions for dedup\n    40→    let pool = get_db_pool(&db).await?;\n    41→    let (existing_fitids, existing_hashes) = get_existing_transaction_data(&pool).await?;\n    42→\n    43→    let duplicates = import::find_duplicate_indices(&transactions, &existing_fitids, &existing_hashes);\n    44→    let total_count = transactions.len();\n    45→    let new_count = total_count - duplicates.len();\n    46→\n    47→    Ok(ImportPreview {\n    48→        format: format.to_string(),\n    49→        account_number,\n    50→        bank_id,\n    51→        transactions,\n    52→        duplicates,\n    53→        total_count,\n    54→        new_count,\n    55→    })\n    56→}\n    57→\n    58→/// Detect CSV configuration from file content\n    59→#[command]\n    60→pub async fn detect_csv_columns(file_path: String) -> Result<CsvColumnInfo, String> {\n    61→    let content = import::read_file_with_encoding(&file_path)?;\n    62→    let config = import::detect_csv_config(&content);\n    63→\n    64→    // Get header names\n    65→    let first_line = content.lines().next().unwrap_or(\"\");\n    66→    let headers: Vec<String> = first_line\n    67→        .split(config.delimiter)\n    68→        .map(|s| s.trim().trim_matches('\"').to_string())\n    69→        .collect();\n    70→\n    71→    // Get sample data (first 3 rows)\n    72→    let mut sample_rows: Vec<Vec<String>> = Vec::new();\n    73→    for line in content.lines().skip(1).take(3) {\n    74→        let row: Vec<String> = line\n    75→            .split(config.delimiter)\n    76→            .map(|s| s.trim().trim_matches('\"').to_string())\n    77→            .collect();\n    78→        sample_rows.push(row);\n    79→    }\n    80→\n    81→    Ok(CsvColumnInfo {\n    82→        headers,\n    83→        sample_rows,\n    84→        detected_config: config,\n    85→    })\n    86→}\n    87→\n    88→#[derive(Debug, Serialize, Deserialize)]\n    89→pub struct CsvColumnInfo {\n    90→    pub headers: Vec<String>,\n    91→    pub sample_rows: Vec<Vec<String>>,\n    92→    pub detected_config: CsvConfig,\n    93→}\n    94→\n    95→/// Confirm and execute the import\n    96→#[command]\n    97→pub async fn import_confirm(\n    98→    file_path: String,\n    99→    account_id: i64,\n   100→    csv_config: Option<CsvConfig>,\n   101→    skip_indices: Vec<usize>,\n   102→    db: tauri::State<'_, DbInstances>,\n   103→) -> Result<ImportResult, String> {\n   104→    let content = import::read_file_with_encoding(&file_path)?;\n   105→    let format = import::detect_format(&content);\n   106→    let filename = std::path::Path::new(&file_path)\n   107→        .file_name()\n   108→        .and_then(|n| n.to_str())\n   109→        .unwrap_or(\"import\")\n   110→        .to_string();\n   111→\n   112→    let (transactions, _, _) = match format {\n   113→        \"ofx\" => import::parse_ofx(&content)?,\n   114→        \"qif\" => {\n   115→            let txs = import::parse_qif(&content)?;\n   116→            (txs, None, None)\n   117→        }\n   118→        \"csv\" => {\n   119→            let config = csv_config.unwrap_or_else(|| import::detect_csv_config(&content));\n   120→            let txs = import::parse_csv(&content, &config)?;\n   121→            (txs, None, None)\n   122→        }\n   123→        _ => return Err(\"Format non reconnu\".to_string()),\n   124→    };\n   125→\n   126→    let pool = get_db_pool(&db).await?;\n   127→\n   128→    // Get existing for dedup\n   129→    let (existing_fitids, existing_hashes) = get_existing_transaction_data(&pool).await?;\n   130→    let auto_dupes = import::find_duplicate_indices(&transactions, &existing_fitids, &existing_hashes);\n   131→\n   132→    // Combine auto-detected duplicates with user-skipped indices\n   133→    let mut skip_set: std::collections::HashSet<usize> = skip_indices.into_iter().collect();\n   134→    for idx in &auto_dupes {\n   135→        skip_set.insert(*idx);\n   136→    }\n   137→\n   138→    // Create import batch\n   139→    let batch_result = sqlx::query(\n   140→        \"INSERT INTO import_batches (filename, format, account_id, transaction_count) VALUES (?, ?, ?, ?)\"\n   141→    )\n   142→    .bind(&filename)\n   143→    .bind(format)\n   144→    .bind(account_id)\n   145→    .bind(0i32)\n   146→    .execute(&pool)\n   147→    .await\n   148→    .map_err(|e| format!(\"Erreur création batch: {}\", e))?;\n   149→\n   150→    let batch_id = batch_result.last_insert_rowid();\n   151→\n   152→    // Get categorization rules for auto-categorization\n   153→    let rules: Vec<(String, i64)> = sqlx::query_as(\n   154→        \"SELECT pattern, series_id FROM categorization_rules ORDER BY match_count DESC\"\n   155→    )\n   156→    .fetch_all(&pool)\n   157→    .await\n   158→    .map_err(|e| format!(\"Erreur chargement règles: {}\", e))?;\n   159→\n   160→    // Insert transactions\n   161→    let mut imported_count = 0usize;\n   162→    for (i, tx) in transactions.iter().enumerate() {\n   163→        if skip_set.contains(&i) {\n   164→            continue;\n   165→        }\n   166→\n   167→        // Auto-categorize based on rules\n   168→        let series_id = find_matching_series(&tx.label, &tx.original_label, &rules);\n   169→\n   170→        sqlx::query(\n   171→            \"INSERT INTO transactions (account_id, date, label, original_label, amount, note, fitid, import_batch_id, series_id)\n   172→             VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\"\n   173→        )\n   174→        .bind(account_id)\n   175→        .bind(&tx.date)\n   176→        .bind(&tx.label)\n   177→        .bind(&tx.original_label)\n   178→        .bind(tx.amount)\n   179→        .bind(&tx.note)\n   180→        .bind(&tx.fitid)\n   181→        .bind(batch_id)\n   182→        .bind(series_id)\n   183→        .execute(&pool)\n   184→        .await\n   185→        .map_err(|e| format!(\"Erreur insertion transaction: {}\", e))?;\n   186→\n   187→        imported_count += 1;\n   188→    }\n   189→\n   190→    // Update batch count\n   191→    sqlx::query(\"UPDATE import_batches SET transaction_count = ? WHERE id = ?\")\n   192→        .bind(imported_count as i32)\n   193→        .bind(batch_id)\n   194→        .execute(&pool)\n   195→        .await\n   196→        .map_err(|e| format!(\"Erreur mise à jour batch: {}\", e))?;\n   197→\n   198→    Ok(ImportResult {\n   199→        batch_id,\n   200→        imported_count,\n   201→        duplicates_skipped: skip_set.len(),\n   202→        account_id,\n   203→    })\n   204→}\n   205→\n   206→/// Rollback an import batch (delete all transactions from a batch)\n   207→#[command]\n   208→pub async fn import_rollback(\n   209→    batch_id: i64,\n   210→    db: tauri::State<'_, DbInstances>,\n   211→) -> Result<usize, String> {\n   212→    let pool = get_db_pool(&db).await?;\n   213→\n   214→    let result = sqlx::query(\"DELETE FROM transactions WHERE import_batch_id = ?\")\n   215→        .bind(batch_id)\n   216→        .execute(&pool)\n   217→        .await\n   218→        .map_err(|e| format!(\"Erreur rollback: {}\", e))?;\n   219→\n   220→    let deleted = result.rows_affected() as usize;\n   221→\n   222→    sqlx::query(\"DELETE FROM import_batches WHERE id = ?\")\n   223→        .bind(batch_id)\n   224→        .execute(&pool)\n   225→        .await\n   226→        .map_err(|e| format!(\"Erreur suppression batch: {}\", e))?;\n   227→\n   228→    Ok(deleted)\n   229→}\n   230→\n   231→// === Helpers ===\n   232→\n   233→async fn get_db_pool(db: &DbInstances) -> Result<sqlx::SqlitePool, String> {\n   234→    let instances = db.0.lock().await;\n   235→    let pool = instances\n   236→        .get(\"sqlite:budgetview.db\")\n   237→        .ok_or(\"Base de données non initialisée\")?;\n   238→\n   239→    match pool {\n   240→        DbPool::Sqlite(pool) => Ok(pool.clone()),\n   241→        _ => Err(\"Type de base de données invalide\".to_string()),\n   242→    }\n   243→}\n   244→\n   245→async fn get_existing_transaction_data(\n   246→    pool: &sqlx::SqlitePool,\n   247→) -> Result<(Vec<String>, Vec<(String, f64, String)>), String> {\n   248→    // Get existing FITIDs\n   249→    let fitid_rows: Vec<(String,)> = sqlx::query_as(\n   250→        \"SELECT fitid FROM transactions WHERE fitid IS NOT NULL AND fitid != ''\"\n   251→    )\n   252→    .fetch_all(pool)\n   253→    .await\n   254→    .map_err(|e| format!(\"Erreur lecture fitids: {}\", e))?;\n   255→    let existing_fitids: Vec<String> = fitid_rows.into_iter().map(|r| r.0).collect();\n   256→\n   257→    // Get existing (date, amount, label) for fuzzy dedup\n   258→    let hash_rows: Vec<(String, f64, String)> = sqlx::query_as(\n   259→        \"SELECT date, amount, label FROM transactions\"\n   260→    )\n   261→    .fetch_all(pool)\n   262→    .await\n   263→    .map_err(|e| format!(\"Erreur lecture transactions: {}\", e))?;\n   264→\n   265→    Ok((existing_fitids, hash_rows))\n   266→}\n   267→\n   268→fn find_matching_series(label: &str, original_label: &str, rules: &[(String, i64)]) -> Option<i64> {\n   269→    let upper_label = label.to_uppercase();\n   270→    let upper_original = original_label.to_uppercase();\n   271→\n   272→    for (pattern, series_id) in rules {\n   273→        let upper_pattern = pattern.to_uppercase();\n   274→        if upper_label.contains(&upper_pattern) || upper_original.contains(&upper_pattern) {\n   275→            return Some(*series_id);\n   276→        }\n   277→    }\n   278→    None\n   279→}\n   280→"}]},"parent_tool_use_id":null,"session_id":"85d56d0a-e499-4451-8cdb-61d43ab7f486","uuid":"4e6b07d5-d72c-4e20-aa01-4ef17414297f","timestamp":"2026-03-17T15:49:46.630Z","tool_use_result":{"type":"text","file":{"filePath":"/home/jeremy/Documents/budgetview-tauri/src-tauri/src/commands.rs","content":"use serde::{Deserialize, Serialize};\nuse tauri::command;\nuse tauri_plugin_sql::{DbInstances, DbPool};\n\nuse crate::import::{\n    self, CsvConfig, ImportPreview, ImportResult, RawTransaction,\n};\n\n#[command]\npub fn greet(name: &str) -> String {\n    format!(\"Bienvenue dans BudgetView, {} !\", name)\n}\n\n/// Parse a file and return a preview of transactions to import\n#[command]\npub async fn import_preview(\n    file_path: String,\n    csv_config: Option<CsvConfig>,\n    db: tauri::State<'_, DbInstances>,\n) -> Result<ImportPreview, String> {\n    // Read file with encoding detection\n    let content = import::read_file_with_encoding(&file_path)?;\n    let format = import::detect_format(&content);\n\n    let (transactions, account_number, bank_id) = match format {\n        \"ofx\" => import::parse_ofx(&content)?,\n        \"qif\" => {\n            let txs = import::parse_qif(&content)?;\n            (txs, None, None)\n        }\n        \"csv\" => {\n            let config = csv_config.unwrap_or_else(|| import::detect_csv_config(&content));\n            let txs = import::parse_csv(&content, &config)?;\n            (txs, None, None)\n        }\n        _ => return Err(\"Format de fichier non reconnu\".to_string()),\n    };\n\n    // Get existing transactions for dedup\n    let pool = get_db_pool(&db).await?;\n    let (existing_fitids, existing_hashes) = get_existing_transaction_data(&pool).await?;\n\n    let duplicates = import::find_duplicate_indices(&transactions, &existing_fitids, &existing_hashes);\n    let total_count = transactions.len();\n    let new_count = total_count - duplicates.len();\n\n    Ok(ImportPreview {\n        format: format.to_string(),\n        account_number,\n        bank_id,\n        transactions,\n        duplicates,\n        total_count,\n        new_count,\n    })\n}\n\n/// Detect CSV configuration from file content\n#[command]\npub async fn detect_csv_columns(file_path: String) -> Result<CsvColumnInfo, String> {\n    let content = import::read_file_with_encoding(&file_path)?;\n    let config = import::detect_csv_config(&content);\n\n    // Get header names\n    let first_line = content.lines().next().unwrap_or(\"\");\n    let headers: Vec<String> = first_line\n        .split(config.delimiter)\n        .map(|s| s.trim().trim_matches('\"').to_string())\n        .collect();\n\n    // Get sample data (first 3 rows)\n    let mut sample_rows: Vec<Vec<String>> = Vec::new();\n    for line in content.lines().skip(1).take(3) {\n        let row: Vec<String> = line\n            .split(config.delimiter)\n            .map(|s| s.trim().trim_matches('\"').to_string())\n            .collect();\n        sample_rows.push(row);\n    }\n\n    Ok(CsvColumnInfo {\n        headers,\n        sample_rows,\n        detected_config: config,\n    })\n}\n\n#[derive(Debug, Serialize, Deserialize)]\npub struct CsvColumnInfo {\n    pub headers: Vec<String>,\n    pub sample_rows: Vec<Vec<String>>,\n    pub detected_config: CsvConfig,\n}\n\n/// Confirm and execute the import\n#[command]\npub async fn import_confirm(\n    file_path: String,\n    account_id: i64,\n    csv_config: Option<CsvConfig>,\n    skip_indices: Vec<usize>,\n    db: tauri::State<'_, DbInstances>,\n) -> Result<ImportResult, String> {\n    let content = import::read_file_with_encoding(&file_path)?;\n    let format = import::detect_format(&content);\n    let filename = std::path::Path::new(&file_path)\n        .file_name()\n        .and_then(|n| n.to_str())\n        .unwrap_or(\"import\")\n        .to_string();\n\n    let (transactions, _, _) = match format {\n        \"ofx\" => import::parse_ofx(&content)?,\n        \"qif\" => {\n            let txs = import::parse_qif(&content)?;\n            (txs, None, None)\n        }\n        \"csv\" => {\n            let config = csv_config.unwrap_or_else(|| import::detect_csv_config(&content));\n            let txs = import::parse_csv(&content, &config)?;\n            (txs, None, None)\n        }\n        _ => return Err(\"Format non reconnu\".to_string()),\n    };\n\n    let pool = get_db_pool(&db).await?;\n\n    // Get existing for dedup\n    let (existing_fitids, existing_hashes) = get_existing_transaction_data(&pool).await?;\n    let auto_dupes = import::find_duplicate_indices(&transactions, &existing_fitids, &existing_hashes);\n\n    // Combine auto-detected duplicates with user-skipped indices\n    let mut skip_set: std::collections::HashSet<usize> = skip_indices.into_iter().collect();\n    for idx in &auto_dupes {\n        skip_set.insert(*idx);\n    }\n\n    // Create import batch\n    let batch_result = sqlx::query(\n        \"INSERT INTO import_batches (filename, format, account_id, transaction_count) VALUES (?, ?, ?, ?)\"\n    )\n    .bind(&filename)\n    .bind(format)\n    .bind(account_id)\n    .bind(0i32)\n    .execute(&pool)\n    .await\n    .map_err(|e| format!(\"Erreur création batch: {}\", e))?;\n\n    let batch_id = batch_result.last_insert_rowid();\n\n    // Get categorization rules for auto-categorization\n    let rules: Vec<(String, i64)> = sqlx::query_as(\n        \"SELECT pattern, series_id FROM categorization_rules ORDER BY match_count DESC\"\n    )\n    .fetch_all(&pool)\n    .await\n    .map_err(|e| format!(\"Erreur chargement règles: {}\", e))?;\n\n    // Insert transactions\n    let mut imported_count = 0usize;\n    for (i, tx) in transactions.iter().enumerate() {\n        if skip_set.contains(&i) {\n            continue;\n        }\n\n        // Auto-categorize based on rules\n        let series_id = find_matching_series(&tx.label, &tx.original_label, &rules);\n\n        sqlx::query(\n            \"INSERT INTO transactions (account_id, date, label, original_label, amount, note, fitid, import_batch_id, series_id)\n             VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\"\n        )\n        .bind(account_id)\n        .bind(&tx.date)\n        .bind(&tx.label)\n        .bind(&tx.original_label)\n        .bind(tx.amount)\n        .bind(&tx.note)\n        .bind(&tx.fitid)\n        .bind(batch_id)\n        .bind(series_id)\n        .execute(&pool)\n        .await\n        .map_err(|e| format!(\"Erreur insertion transaction: {}\", e))?;\n\n        imported_count += 1;\n    }\n\n    // Update batch count\n    sqlx::query(\"UPDATE import_batches SET transaction_count = ? WHERE id = ?\")\n        .bind(imported_count as i32)\n        .bind(batch_id)\n        .execute(&pool)\n        .await\n        .map_err(|e| format!(\"Erreur mise à jour batch: {}\", e))?;\n\n    Ok(ImportResult {\n        batch_id,\n        imported_count,\n        duplicates_skipped: skip_set.len(),\n        account_id,\n    })\n}\n\n/// Rollback an import batch (delete all transactions from a batch)\n#[command]\npub async fn import_rollback(\n    batch_id: i64,\n    db: tauri::State<'_, DbInstances>,\n) -> Result<usize, String> {\n    let pool = get_db_pool(&db).await?;\n\n    let result = sqlx::query(\"DELETE FROM transactions WHERE import_batch_id = ?\")\n        .bind(batch_id)\n        .execute(&pool)\n        .await\n        .map_err(|e| format!(\"Erreur rollback: {}\", e))?;\n\n    let deleted = result.rows_affected() as usize;\n\n    sqlx::query(\"DELETE FROM import_batches WHERE id = ?\")\n        .bind(batch_id)\n        .execute(&pool)\n        .await\n        .map_err(|e| format!(\"Erreur suppression batch: {}\", e))?;\n\n    Ok(deleted)\n}\n\n// === Helpers ===\n\nasync fn get_db_pool(db: &DbInstances) -> Result<sqlx::SqlitePool, String> {\n    let instances = db.0.lock().await;\n    let pool = instances\n        .get(\"sqlite:budgetview.db\")\n        .ok_or(\"Base de données non initialisée\")?;\n\n    match pool {\n        DbPool::Sqlite(pool) => Ok(pool.clone()),\n        _ => Err(\"Type de base de données invalide\".to_string()),\n    }\n}\n\nasync fn get_existing_transaction_data(\n    pool: &sqlx::SqlitePool,\n) -> Result<(Vec<String>, Vec<(String, f64, String)>), String> {\n    // Get existing FITIDs\n    let fitid_rows: Vec<(String,)> = sqlx::query_as(\n        \"SELECT fitid FROM transactions WHERE fitid IS NOT NULL AND fitid != ''\"\n    )\n    .fetch_all(pool)\n    .await\n    .map_err(|e| format!(\"Erreur lecture fitids: {}\", e))?;\n    let existing_fitids: Vec<String> = fitid_rows.into_iter().map(|r| r.0).collect();\n\n    // Get existing (date, amount, label) for fuzzy dedup\n    let hash_rows: Vec<(String, f64, String)> = sqlx::query_as(\n        \"SELECT date, amount, label FROM transactions\"\n    )\n    .fetch_all(pool)\n    .await\n    .map_err(|e| format!(\"Erreur lecture transactions: {}\", e))?;\n\n    Ok((existing_fitids, hash_rows))\n}\n\nfn find_matching_series(label: &str, original_label: &str, rules: &[(String, i64)]) -> Option<i64> {\n    let upper_label = label.to_uppercase();\n    let upper_original = original_label.to_uppercase();\n\n    for (pattern, series_id) in rules {\n        let upper_pattern = pattern.to_uppercase();\n        if upper_label.contains(&upper_pattern) || upper_original.contains(&upper_pattern) {\n            return Some(*series_id);\n        }\n    }\n    None\n}\n","numLines":280,"startLine":1,"totalLines":280}}}
