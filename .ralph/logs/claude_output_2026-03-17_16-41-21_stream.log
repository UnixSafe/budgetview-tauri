{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015HbJ7uCBKP7cY29yXH5mkf","type":"tool_result","content":"     1→import { query, execute } from './db';\n     2→import type { Account } from '$lib/types';\n     3→\n     4→class AccountStore {\n     5→\taccounts = $state<Account[]>([]);\n     6→\tloading = $state(false);\n     7→\terror = $state<string | null>(null);\n     8→\n     9→\tasync load() {\n    10→\t\tthis.loading = true;\n    11→\t\tthis.error = null;\n    12→\t\ttry {\n    13→\t\t\tthis.accounts = await query<Account>(\n    14→\t\t\t\t'SELECT * FROM accounts WHERE is_active = 1 ORDER BY name'\n    15→\t\t\t);\n    16→\t\t} catch (e) {\n    17→\t\t\tthis.error = e instanceof Error ? e.message : 'Erreur inconnue';\n    18→\t\t} finally {\n    19→\t\t\tthis.loading = false;\n    20→\t\t}\n    21→\t}\n    22→\n    23→\tasync create(data: { name: string; account_number?: string; bank_name?: string; account_type: string; initial_balance: number }) {\n    24→\t\tawait execute(\n    25→\t\t\t'INSERT INTO accounts (name, account_number, bank_name, account_type, initial_balance) VALUES ($1, $2, $3, $4, $5)',\n    26→\t\t\t[data.name, data.account_number ?? null, data.bank_name ?? null, data.account_type, data.initial_balance]\n    27→\t\t);\n    28→\t\tawait this.load();\n    29→\t}\n    30→\n    31→\tasync update(id: number, data: Partial<{ name: string; account_number: string | null; bank_name: string | null; account_type: string; initial_balance: number }>) {\n    32→\t\tconst fields: string[] = [];\n    33→\t\tconst values: unknown[] = [];\n    34→\t\tlet i = 1;\n    35→\n    36→\t\tfor (const [key, val] of Object.entries(data)) {\n    37→\t\t\tif (val !== undefined) {\n    38→\t\t\t\tfields.push(`${key} = $${i++}`);\n    39→\t\t\t\tvalues.push(val);\n    40→\t\t\t}\n    41→\t\t}\n    42→\n    43→\t\tif (fields.length > 0) {\n    44→\t\t\tvalues.push(id);\n    45→\t\t\tawait execute(`UPDATE accounts SET ${fields.join(', ')} WHERE id = $${i}`, values);\n    46→\t\t\tawait this.load();\n    47→\t\t}\n    48→\t}\n    49→\n    50→\tasync remove(id: number) {\n    51→\t\tawait execute('UPDATE accounts SET is_active = 0 WHERE id = $1', [id]);\n    52→\t\tawait this.load();\n    53→\t}\n    54→\n    55→\tgetBalance(account: Account): number {\n    56→\t\treturn account.initial_balance;\n    57→\t}\n    58→\n    59→\tget totalBalance(): number {\n    60→\t\treturn this.accounts.reduce((sum, a) => sum + a.initial_balance, 0);\n    61→\t}\n    62→}\n    63→\n    64→export const accountStore = new AccountStore();\n    65→"}]},"parent_tool_use_id":null,"session_id":"85d56d0a-e499-4451-8cdb-61d43ab7f486","uuid":"95038959-80f9-4944-8c3a-c6ee72ae4755","timestamp":"2026-03-17T15:50:10.793Z","tool_use_result":{"type":"text","file":{"filePath":"/home/jeremy/Documents/budgetview-tauri/src/lib/stores/accounts.ts","content":"import { query, execute } from './db';\nimport type { Account } from '$lib/types';\n\nclass AccountStore {\n\taccounts = $state<Account[]>([]);\n\tloading = $state(false);\n\terror = $state<string | null>(null);\n\n\tasync load() {\n\t\tthis.loading = true;\n\t\tthis.error = null;\n\t\ttry {\n\t\t\tthis.accounts = await query<Account>(\n\t\t\t\t'SELECT * FROM accounts WHERE is_active = 1 ORDER BY name'\n\t\t\t);\n\t\t} catch (e) {\n\t\t\tthis.error = e instanceof Error ? e.message : 'Erreur inconnue';\n\t\t} finally {\n\t\t\tthis.loading = false;\n\t\t}\n\t}\n\n\tasync create(data: { name: string; account_number?: string; bank_name?: string; account_type: string; initial_balance: number }) {\n\t\tawait execute(\n\t\t\t'INSERT INTO accounts (name, account_number, bank_name, account_type, initial_balance) VALUES ($1, $2, $3, $4, $5)',\n\t\t\t[data.name, data.account_number ?? null, data.bank_name ?? null, data.account_type, data.initial_balance]\n\t\t);\n\t\tawait this.load();\n\t}\n\n\tasync update(id: number, data: Partial<{ name: string; account_number: string | null; bank_name: string | null; account_type: string; initial_balance: number }>) {\n\t\tconst fields: string[] = [];\n\t\tconst values: unknown[] = [];\n\t\tlet i = 1;\n\n\t\tfor (const [key, val] of Object.entries(data)) {\n\t\t\tif (val !== undefined) {\n\t\t\t\tfields.push(`${key} = $${i++}`);\n\t\t\t\tvalues.push(val);\n\t\t\t}\n\t\t}\n\n\t\tif (fields.length > 0) {\n\t\t\tvalues.push(id);\n\t\t\tawait execute(`UPDATE accounts SET ${fields.join(', ')} WHERE id = $${i}`, values);\n\t\t\tawait this.load();\n\t\t}\n\t}\n\n\tasync remove(id: number) {\n\t\tawait execute('UPDATE accounts SET is_active = 0 WHERE id = $1', [id]);\n\t\tawait this.load();\n\t}\n\n\tgetBalance(account: Account): number {\n\t\treturn account.initial_balance;\n\t}\n\n\tget totalBalance(): number {\n\t\treturn this.accounts.reduce((sum, a) => sum + a.initial_balance, 0);\n\t}\n}\n\nexport const accountStore = new AccountStore();\n","numLines":65,"startLine":1,"totalLines":65}}}
