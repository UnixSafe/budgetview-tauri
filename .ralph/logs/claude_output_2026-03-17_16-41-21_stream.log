{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Sq9FUVAwpkYTsp8Jzg5j7R","type":"tool_result","content":"     1→<script lang=\"ts\">\n     2→\timport { onMount } from 'svelte';\n     3→\timport { Wallet, TrendingUp, TrendingDown, ArrowLeftRight, Landmark } from 'lucide-svelte';\n     4→\timport { formatCurrency, ACCOUNT_TYPE_LABELS, BUDGET_AREA_LABELS } from '$lib/utils/format';\n     5→\timport { accountStore } from '$lib/stores/accounts';\n     6→\timport { budgetStore } from '$lib/stores/budget';\n     7→\timport { query } from '$lib/stores/db';\n     8→\timport type { DashboardSummary, BudgetLineItem } from '$lib/types';\n     9→\n    10→\tlet summary = $state<DashboardSummary>({\n    11→\t\ttotal_balance: 0,\n    12→\t\tmonth_income: 0,\n    13→\t\tmonth_expenses: 0,\n    14→\t\ttransaction_count: 0\n    15→\t});\n    16→\n    17→\tlet recentTransactions = $state<{ date: string; label: string; amount: number; account_name: string }[]>([]);\n    18→\n    19→\tonMount(async () => {\n    20→\t\tawait accountStore.load();\n    21→\t\tawait budgetStore.loadBudgetView();\n    22→\n    23→\t\tconst now = new Date();\n    24→\t\tconst year = now.getFullYear();\n    25→\t\tconst month = now.getMonth() + 1;\n    26→\t\tconst startDate = `${year}-${String(month).padStart(2, '0')}-01`;\n    27→\t\tconst endMonth = month === 12 ? 1 : month + 1;\n    28→\t\tconst endYear = month === 12 ? year + 1 : year;\n    29→\t\tconst endDate = `${endYear}-${String(endMonth).padStart(2, '0')}-01`;\n    30→\n    31→\t\tconst [incomeResult, expenseResult, countResult, recent] = await Promise.all([\n    32→\t\t\tquery<{ total: number }>('SELECT COALESCE(SUM(amount), 0) as total FROM transactions WHERE date >= $1 AND date < $2 AND amount > 0', [startDate, endDate]),\n    33→\t\t\tquery<{ total: number }>('SELECT COALESCE(SUM(amount), 0) as total FROM transactions WHERE date >= $1 AND date < $2 AND amount < 0', [startDate, endDate]),\n    34→\t\t\tquery<{ count: number }>('SELECT COUNT(*) as count FROM transactions WHERE date >= $1 AND date < $2', [startDate, endDate]),\n    35→\t\t\tquery<{ date: string; label: string; amount: number; account_name: string }>(\n    36→\t\t\t\t`SELECT t.date, t.label, t.amount, a.name as account_name\n    37→\t\t\t\t FROM transactions t LEFT JOIN accounts a ON t.account_id = a.id\n    38→\t\t\t\t ORDER BY t.date DESC, t.id DESC LIMIT 10`\n    39→\t\t\t)\n    40→\t\t]);\n    41→\n    42→\t\tsummary = {\n    43→\t\t\ttotal_balance: accountStore.totalBalance,\n    44→\t\t\tmonth_income: incomeResult[0]?.total ?? 0,\n    45→\t\t\tmonth_expenses: expenseResult[0]?.total ?? 0,\n    46→\t\t\ttransaction_count: countResult[0]?.count ?? 0\n    47→\t\t};\n    48→\n    49→\t\trecentTransactions = recent;\n    50→\t});\n    51→</script>\n    52→\n    53→<svelte:head>\n    54→\t<title>Tableau de bord — BudgetView</title>\n    55→</svelte:head>\n    56→\n    57→<div class=\"space-y-6\">\n    58→\t<h1 class=\"text-2xl font-bold text-text-primary\">Tableau de bord</h1>\n    59→\n    60→\t<!-- Cartes résumé -->\n    61→\t<div class=\"grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4\">\n    62→\t\t<div class=\"rounded-xl border border-border bg-bg-card p-5\">\n    63→\t\t\t<div class=\"flex items-center gap-3\">\n    64→\t\t\t\t<div class=\"rounded-lg bg-accent/10 p-2\">\n    65→\t\t\t\t\t<Wallet size={20} class=\"text-accent\" />\n    66→\t\t\t\t</div>\n    67→\t\t\t\t<div>\n    68→\t\t\t\t\t<p class=\"text-sm text-text-secondary\">Solde total</p>\n    69→\t\t\t\t\t<p class=\"text-xl font-bold text-text-primary\">{formatCurrency(summary.total_balance)}</p>\n    70→\t\t\t\t</div>\n    71→\t\t\t</div>\n    72→\t\t</div>\n    73→\n    74→\t\t<div class=\"rounded-xl border border-border bg-bg-card p-5\">\n    75→\t\t\t<div class=\"flex items-center gap-3\">\n    76→\t\t\t\t<div class=\"rounded-lg bg-income/10 p-2\">\n    77→\t\t\t\t\t<TrendingUp size={20} class=\"text-income\" />\n    78→\t\t\t\t</div>\n    79→\t\t\t\t<div>\n    80→\t\t\t\t\t<p class=\"text-sm text-text-secondary\">Revenus du mois</p>\n    81→\t\t\t\t\t<p class=\"text-xl font-bold text-income\">{formatCurrency(summary.month_income)}</p>\n    82→\t\t\t\t</div>\n    83→\t\t\t</div>\n    84→\t\t</div>\n    85→\n    86→\t\t<div class=\"rounded-xl border border-border bg-bg-card p-5\">\n    87→\t\t\t<div class=\"flex items-center gap-3\">\n    88→\t\t\t\t<div class=\"rounded-lg bg-expense/10 p-2\">\n    89→\t\t\t\t\t<TrendingDown size={20} class=\"text-expense\" />\n    90→\t\t\t\t</div>\n    91→\t\t\t\t<div>\n    92→\t\t\t\t\t<p class=\"text-sm text-text-secondary\">Dépenses du mois</p>\n    93→\t\t\t\t\t<p class=\"text-xl font-bold text-expense\">{formatCurrency(summary.month_expenses)}</p>\n    94→\t\t\t\t</div>\n    95→\t\t\t</div>\n    96→\t\t</div>\n    97→\n    98→\t\t<div class=\"rounded-xl border border-border bg-bg-card p-5\">\n    99→\t\t\t<div class=\"flex items-center gap-3\">\n   100→\t\t\t\t<div class=\"rounded-lg bg-accent/10 p-2\">\n   101→\t\t\t\t\t<ArrowLeftRight size={20} class=\"text-accent\" />\n   102→\t\t\t\t</div>\n   103→\t\t\t\t<div>\n   104→\t\t\t\t\t<p class=\"text-sm text-text-secondary\">Transactions</p>\n   105→\t\t\t\t\t<p class=\"text-xl font-bold text-text-primary\">{summary.transaction_count}</p>\n   106→\t\t\t\t</div>\n   107→\t\t\t</div>\n   108→\t\t</div>\n   109→\t</div>\n   110→\n   111→\t<div class=\"grid grid-cols-1 gap-6 lg:grid-cols-2\">\n   112→\t\t<!-- Comptes -->\n   113→\t\t<div class=\"rounded-xl border border-border bg-bg-card p-5\">\n   114→\t\t\t<h2 class=\"mb-4 text-lg font-semibold text-text-primary\">Comptes</h2>\n   115→\t\t\t{#if accountStore.accounts.length === 0}\n   116→\t\t\t\t<p class=\"text-sm text-text-muted\">Aucun compte configuré</p>\n   117→\t\t\t{:else}\n   118→\t\t\t\t<div class=\"space-y-3\">\n   119→\t\t\t\t\t{#each accountStore.accounts as account}\n   120→\t\t\t\t\t\t<div class=\"flex items-center justify-between\">\n   121→\t\t\t\t\t\t\t<div class=\"flex items-center gap-3\">\n   122→\t\t\t\t\t\t\t\t<Landmark size={16} class=\"text-text-muted\" />\n   123→\t\t\t\t\t\t\t\t<div>\n   124→\t\t\t\t\t\t\t\t\t<p class=\"text-sm font-medium text-text-primary\">{account.name}</p>\n   125→\t\t\t\t\t\t\t\t\t<p class=\"text-xs text-text-muted\">{ACCOUNT_TYPE_LABELS[account.account_type]}</p>\n   126→\t\t\t\t\t\t\t\t</div>\n   127→\t\t\t\t\t\t\t</div>\n   128→\t\t\t\t\t\t\t<span class=\"text-sm font-semibold {account.initial_balance >= 0 ? 'text-income' : 'text-expense'}\">\n   129→\t\t\t\t\t\t\t\t{formatCurrency(account.initial_balance)}\n   130→\t\t\t\t\t\t\t</span>\n   131→\t\t\t\t\t\t</div>\n   132→\t\t\t\t\t{/each}\n   133→\t\t\t\t</div>\n   134→\t\t\t{/if}\n   135→\t\t</div>\n   136→\n   137→\t\t<!-- Dernières transactions -->\n   138→\t\t<div class=\"rounded-xl border border-border bg-bg-card p-5\">\n   139→\t\t\t<h2 class=\"mb-4 text-lg font-semibold text-text-primary\">Dernières transactions</h2>\n   140→\t\t\t{#if recentTransactions.length === 0}\n   141→\t\t\t\t<p class=\"text-sm text-text-muted\">Aucune transaction</p>\n   142→\t\t\t{:else}\n   143→\t\t\t\t<div class=\"space-y-2\">\n   144→\t\t\t\t\t{#each recentTransactions as tx}\n   145→\t\t\t\t\t\t<div class=\"flex items-center justify-between text-sm\">\n   146→\t\t\t\t\t\t\t<div>\n   147→\t\t\t\t\t\t\t\t<p class=\"font-medium text-text-primary\">{tx.label}</p>\n   148→\t\t\t\t\t\t\t\t<p class=\"text-xs text-text-muted\">{tx.account_name}</p>\n   149→\t\t\t\t\t\t\t</div>\n   150→\t\t\t\t\t\t\t<span class=\"font-medium {tx.amount >= 0 ? 'text-income' : 'text-expense'}\">\n   151→\t\t\t\t\t\t\t\t{formatCurrency(tx.amount)}\n   152→\t\t\t\t\t\t\t</span>\n   153→\t\t\t\t\t\t</div>\n   154→\t\t\t\t\t{/each}\n   155→\t\t\t\t</div>\n   156→\t\t\t{/if}\n   157→\t\t</div>\n   158→\t</div>\n   159→\n   160→\t<!-- Budget du mois -->\n   161→\t{#if budgetStore.budgetLines.length > 0}\n   162→\t\t<div class=\"rounded-xl border border-border bg-bg-card p-5\">\n   163→\t\t\t<h2 class=\"mb-4 text-lg font-semibold text-text-primary\">Budget du mois</h2>\n   164→\t\t\t<div class=\"space-y-3\">\n   165→\t\t\t\t{#each budgetStore.budgetLines.filter(l => l.planned_amount !== 0) as line}\n   166→\t\t\t\t\t{@const pct = line.planned_amount === 0 ? 0 : Math.min(Math.abs(line.actual_amount) / Math.abs(line.planned_amount) * 100, 100)}\n   167→\t\t\t\t\t{@const over = line.budget_area !== 'income' && Math.abs(line.actual_amount) > Math.abs(line.planned_amount)}\n   168→\t\t\t\t\t<div>\n   169→\t\t\t\t\t\t<div class=\"flex items-center justify-between text-sm mb-1\">\n   170→\t\t\t\t\t\t\t<span class=\"text-text-primary\">{line.series_name}</span>\n   171→\t\t\t\t\t\t\t<span class=\"{over ? 'text-expense' : 'text-text-secondary'}\">\n   172→\t\t\t\t\t\t\t\t{formatCurrency(line.actual_amount)} / {formatCurrency(line.planned_amount)}\n   173→\t\t\t\t\t\t\t</span>\n   174→\t\t\t\t\t\t</div>\n   175→\t\t\t\t\t\t<div class=\"h-1.5 w-full rounded-full bg-bg-hover\">\n   176→\t\t\t\t\t\t\t<div\n   177→\t\t\t\t\t\t\t\tclass=\"h-1.5 rounded-full {over ? 'bg-danger' : 'bg-accent'}\"\n   178→\t\t\t\t\t\t\t\tstyle=\"width: {pct}%\"\n   179→\t\t\t\t\t\t\t></div>\n   180→\t\t\t\t\t\t</div>\n   181→\t\t\t\t\t</div>\n   182→\t\t\t\t{/each}\n   183→\t\t\t</div>\n   184→\t\t</div>\n   185→\t{/if}\n   186→</div>\n   187→"}]},"parent_tool_use_id":"toolu_01Wwqnwxr5nWEsa7JVeguQCH","session_id":"85d56d0a-e499-4451-8cdb-61d43ab7f486","uuid":"7b6e186f-39cb-422c-882d-e1489c94a3cb","timestamp":"2026-03-17T15:43:39.339Z"}
