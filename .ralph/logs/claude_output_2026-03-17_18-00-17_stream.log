n border-b border-border bg-bg-card px-4 py-3\">\n   269→\t\t\t\t<h3 class=\"text-sm font-semibold text-text-primary\">Aperçu des transactions</h3>\n   270→\t\t\t\t{#if preview.transactions.length > 20}\n   271→\t\t\t\t\t<button\n   272→\t\t\t\t\t\tonclick={() => (showAllTransactions = !showAllTransactions)}\n   273→\t\t\t\t\t\tclass=\"flex items-center gap-1 text-xs text-accent hover:text-accent-hover\"\n   274→\t\t\t\t\t>\n   275→\t\t\t\t\t\t{showAllTransactions ? 'Réduire' : `Voir les ${preview.transactions.length} transactions`}\n   276→\t\t\t\t\t\t{#if showAllTransactions}\n   277→\t\t\t\t\t\t\t<ChevronUp size={14} />\n   278→\t\t\t\t\t\t{:else}\n   279→\t\t\t\t\t\t\t<ChevronDown size={14} />\n   280→\t\t\t\t\t\t{/if}\n   281→\t\t\t\t\t</button>\n   282→\t\t\t\t{/if}\n   283→\t\t\t</div>\n   284→\t\t\t<table class=\"w-full\">\n   285→\t\t\t\t<thead>\n   286→\t\t\t\t\t<tr class=\"border-b border-border bg-bg-secondary text-left text-xs text-text-secondary\">\n   287→\t\t\t\t\t\t<th class=\"px-4 py-2 font-medium\">Statut</th>\n   288→\t\t\t\t\t\t<th class=\"px-4 py-2 font-medium\">Date</th>\n   289→\t\t\t\t\t\t<th class=\"px-4 py-2 font-medium\">Libellé</th>\n   290→\t\t\t\t\t\t<th class=\"px-4 py-2 text-right font-medium\">Montant</th>\n   291→\t\t\t\t\t</tr>\n   292→\t\t\t\t</thead>\n   293→\t\t\t\t<tbody>\n   294→\t\t\t\t\t{#each displayedTransactions as tx, i}\n   295→\t\t\t\t\t\t{@const isDuplicate = duplicateSet.has(i)}\n   296→\t\t\t\t\t\t<tr class=\"border-b border-border text-sm {isDuplicate ? 'opacity-40' : ''}\">\n   297→\t\t\t\t\t\t\t<td class=\"px-4 py-2\">\n   298→\t\t\t\t\t\t\t\t{#if isDuplicate}\n   299→\t\t\t\t\t\t\t\t\t<span class=\"inline-flex items-center gap-1 rounded-md bg-warning/10 px-2 py-0.5 text-xs text-warning\">\n   300→\t\t\t\t\t\t\t\t\t\t<AlertTriangle size={12} />\n   301→\t\t\t\t\t\t\t\t\t\tDoublon\n   302→\t\t\t\t\t\t\t\t\t</span>\n   303→\t\t\t\t\t\t\t\t{:else}\n   304→\t\t\t\t\t\t\t\t\t<span class=\"inline-flex items-center gap