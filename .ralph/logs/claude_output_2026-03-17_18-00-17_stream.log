{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UejdzcEKtyQdmV3MhugdfF","type":"tool_result","content":"     1→use serde::{Deserialize, Serialize};\n     2→use tauri::command;\n     3→use tauri_plugin_sql::{DbInstances, DbPool};\n     4→\n     5→use crate::import::{\n     6→    self, CsvConfig, ImportPreview, ImportResult,\n     7→};\n     8→\n     9→#[command]\n    10→pub fn greet(name: &str) -> String {\n    11→    format!(\"Bienvenue dans BudgetView, {} !\", name)\n    12→}\n    13→\n    14→/// Parse a file and return a preview of transactions to import\n    15→#[command]\n    16→pub async fn import_preview(\n    17→    file_path: String,\n    18→    csv_config: Option<CsvConfig>,\n    19→    db: tauri::State<'_, DbInstances>,\n    20→) -> Result<ImportPreview, String> {\n    21→    // Read file with encoding detection\n    22→    let content = import::read_file_with_encoding(&file_path)?;\n    23→    let format = import::detect_format(&content);\n    24→\n    25→    let (transactions, account_number, bank_id) = match format {\n    26→        \"ofx\" => import::parse_ofx(&content)?,\n    27→        \"qif\" => {\n    28→            let txs = import::parse_qif(&content)?;\n    29→            (txs, None, None)\n    30→        }\n    31→        \"csv\" => {\n    32→            let config = csv_config.unwrap_or_else(|| import::detect_csv_config(&content));\n    33→            let txs = import::parse_csv(&content, &config)?;\n    34→            (txs, None, None)\n    35→        }\n    36→        _ => return Err(\"Format de fichier non reconnu\".to_string()),\n    37→    };\n    38→\n    39→    // Get existing transactions for dedup\n    40→    let pool = get_db_pool(&db).await?;\n    41→    let (existing_fitids, existing_hashes) = get_existing_transaction_data(&pool).await?;\n    42→\n    43→    let duplicates = import::find_duplicate_indices(&transactions, &existing_fitids, &existing_hashes);\n    44→    let total_count = transactions.len();\n    45→    let new_count = total_count - duplicates.len();\n    46→\n    47→    Ok(ImportPreview {\n    48→        format: format.to_string(),\n    49→        account_number,\n    50→        bank_id,\n    51→        transactions,\n    52→        duplicates,\n    53→        total_count,\n    54→        new_count,\n    55→    })\n    56→}\n    57→\n    58→/// Detect CSV configuration from file content\n    59→#[command]\n    60→pub async fn detect_csv_columns(file_path: String) -> Result<CsvColumnInfo, String> {\n    61→    let content = import::read_file_with_encoding(&file_path)?;\n    62→    let config = import::detect_csv_config(&content);\n    63→\n    64→    // Get header names\n    65→    let first_line = content.lines().next().unwrap_or(\"\");\n    66→    let headers: Vec<String> = first_line\n    67→        .split(config.delimiter)\n    68→        .map(|s| s.trim().trim_matches('\"').to_string())\n    69→        .collect();\n    70→\n    71→    // Get sample data (first 3 rows)\n    72→    let mut sample_rows: Vec<Vec<String>> = Vec::new();\n    73→    for line in content.lines().skip(1).take(3) {\n    74→        let row: Vec<String> = line\n    75→            .split(config.delimiter)\n    76→            .map(|s| s.trim().trim_matches('\"').to_string())\n    77→            .collect();\n    78→        sample_rows.push(row);\n    79→    }\n    80→\n    81→    Ok(CsvColumnInfo {\n    82→        headers,\n    83→        sample_rows,\n    84→        detected_config: config,\n    85→    })\n    86→}\n    87→\n    88→#[derive(Debug, Serialize, Deserialize)]\n    89→pub struct CsvColumnInfo {\n    90→    pub headers: Vec<String>,\n    91→    pub sample_rows: Vec<Vec<String>>,\n    92→    pub detected_config: CsvConfig,\n    93→}\n    94→\n    95→/// Confirm and execute the import\n    96→#[command]\n    97→pub async fn import_confirm(\n    98→    file_path: String,\n    99→    account_id: i64,\n   100→    csv_config: Option<CsvConfig>,\n   101→    skip_indices: Vec<usize>,\n   102→    db: tauri::State<'_, DbInstances>,\n   103→) -> Result<ImportResult, String> {\n   104→    let content = import::read_file_with_encoding(&file_path)?;\n   105→    let format = import::detect_format(&content);\n   106→    let filename = std::path::Path::new(&file_path)\n   107→        .file_name()\n   108→        .and_then(|n| n.to_str())\n   109→        .unwrap_or(\"import\")\n   110→        .to_string();\n   111→\n   112→    let (transactions, _, _) = match format {\n   113→        \"ofx\" => import::parse_ofx(&content)?,\n   114→        \"qif\" => {\n   115→            let txs = import::parse_qif(&content)?;\n   116→            (txs, None, None)\n   117→        }\n   118→        \"csv\" => {\n   119→            let config = csv_config.unwrap_or_else(|| import::detect_csv_config(&content));\n   120→            let txs = import::parse_csv(&content, &config)?;\n   121→            (txs, None, None)\n   122→        }\n   123→        _ => return Err(\"Format non reconnu\".to_string()),\n   124→    };\n   125→\n   126→    let pool = get_db_pool(&db).await?;\n   127→\n   128→    // Get existing for dedup\n   129→    let (existing_fitids, existing_hashes) = get_existing_transaction_data(&pool).await?;\n   130→    let auto_dupes = import::find_duplicate_indices(&transactions, &existing_fitids, &existing_hashes);\n   131→\n   132→    // Combine auto-detected duplicates with user-skipped indices\n   133→    let mut skip_set: std::collections::HashSet<usize> = skip_indices.into_iter().collect();\n   134→    for idx in &auto_dupes {\n   135→        skip_set.insert(*idx);\n   136→    }\n   137→\n   138→    // Create import batch\n   139→    let batch_result = sqlx::query(\n   140→        \"INSERT INTO import_batches (filename, format, account_id, transaction_count) VALUES (?, ?, ?, ?)\"\n   141→    )\n   142→    .bind(&filename)\n   143→    .bind(format)\n   144→    .bind(account_id)\n   145→    .bind(0i32)\n   146→    .execute(&pool)\n   147→    .await\n   148→    .map_err(|e| format!(\"Erreur création batch: {}\", e))?;\n   149→\n   150→    let batch_id = batch_result.last_insert_rowid();\n   151→\n   152→    // Get categorization rules for auto-categorization\n   153→    let rules: Vec<(String, i64)> = sqlx::query_as(\n   154→        \"SELECT pattern, series_id FROM categorization_rules ORDER BY match_count DESC\"\n   155→    )\n   156→    .fetch_all(&pool)\n   157→    .await\n   158→    .map_err(|e| format!(\"Erreur chargement règles: {}\", e))?;\n   159→\n   160→    // Insert transactions\n   161→    let mut imported_count = 0usize;\n   162→    for (i, tx) in transactions.iter().enumerate() {\n   163→        if skip_set.contains(&i) {\n   164→            continue;\n   165→        }\n   166→\n   167→        // Auto-categorize based on rules\n   168→        let series_id = find_matching_series(&tx.label, &tx.original_label, &rules);\n   169→\n   170→        sqlx::query(\n   171→            \"INSERT INTO transactions (account_id, date, label, original_label, amount, note, fitid, import_batch_id, series_id)\n   172→             VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\"\n   173→        )\n   174→        .bind(account_id)\n   175→        .bind(&tx.date)\n   176→        .bind(&tx.label)\n   177→        .bind(&tx.original_label)\n   178→        .bind(tx.amount)\n   179→        .bind(&tx.note)\n   180→        .bind(&tx.fitid)\n   181→        .bind(batch_id)\n   182→        .bind(series_id)\n   183→        .execute(&pool)\n   184→        .await\n   185→        .map_err(|e| format!(\"Erreur insertion transaction: {}\", e))?;\n   186→\n   187→        imported_count += 1;\n   188→    }\n   189→\n   190→    // Update batch count\n   191→    sqlx::query(\"UPDATE import_batches SET transaction_count = ? WHERE id = ?\")\n   192→        .bind(imported_count as i32)\n   193→        .bind(batch_id)\n   194→        .execute(&pool)\n   195→        .await\n   196→        .map_err(|e| format!(\"Erreur mise à jour batch: {}\", e))?;\n   197→\n   198→    Ok(ImportResult {\n   199→        batch_id,\n   200→        imported_count,\n   201→        duplicates_skipped: skip_set.len(),\n   202→        account_id,\n   203→    })\n   204→}\n   205→\n   206→/// Rollback an import batch (delete all transactions from a batch)\n   207→#[command]\n   208→pub async fn import_rollback(\n   209→    batch_id: i64,\n   210→    db: tauri::State<'_, DbInstances>,\n   211→) -> Result<usize, String> {\n   212→    let pool = get_db_pool(&db).await?;\n   213→\n   214→    let result = sqlx::query(\"DELETE FROM transactions WHERE import_batch_id = ?\")\n   215→        .bind(batch_id)\n   216→        .execute(&pool)\n   217→        .await\n   218→        .map_err(|e| format!(\"Erreur rollback: {}\", e))?;\n   219→\n   220→    let deleted = result.rows_affected() as usize;\n   221→\n   222→    sqlx::query(\"DELETE FROM import_batches WHERE id = ?\")\n   223→        .bind(batch_id)\n   224→        .execute(&pool)\n   225→        .await\n   226→        .map_err(|e| format!(\"Erreur suppression batch: {}\", e))?;\n   227→\n   228→    Ok(deleted)\n   229→}\n   230→\n   231→// === Helpers ===\n   232→\n   233→async fn get_db_pool(db: &DbInstances) -> Result<sqlx::SqlitePool, String> {\n   234→    let instances = db.0.read().await;\n   235→    let pool = instances\n   236→        .get(\"sqlite:budgetview.db\")\n   237→        .ok_or(\"Base de données non initialisée\")?;\n   238→\n   239→    let DbPool::Sqlite(pool) = pool;\n   240→    Ok(pool.clone())\n   241→}\n   242→\n   243→async fn get_existing_transaction_data(\n   244→    pool: &sqlx::SqlitePool,\n   245→) -> Result<(Vec<String>, Vec<(String, f64, String)>), String> {\n   246→    // Get existing FITIDs\n   247→    let fitid_rows: Vec<(String,)> = sqlx::query_as(\n   248→        \"SELECT fitid FROM transactions WHERE fitid IS NOT NULL AND fitid != ''\"\n   249→    )\n   250→    .fetch_all(pool)\n   251→    .await\n   252→    .map_err(|e| format!(\"Erreur lecture fitids: {}\", e))?;\n   253→    let existing_fitids: Vec<String> = fitid_rows.into_iter().map(|r| r.0).collect();\n   254→\n   255→    // Get existing (date, amount, label) for fuzzy dedup\n   256→    let hash_rows: Vec<(String, f64, String)> = sqlx::query_as(\n   257→        \"SELECT date, amount, label FROM transactions\"\n   258→    )\n   259→    .fetch_all(pool)\n   260→    .await\n   261→    .map_err(|e| format!(\"Erreur lecture transactions: {}\", e))?;\n   262→\n   263→    Ok((existing_fitids, hash_rows))\n   264→}\n   265→\n   266→fn find_matching_series(label: &str, original_label: &str, rules: &[(String, i64)]) -> Option<i64> {\n   267→    let upper_label = label.to_uppercase();\n   268→    let upper_original = original_label.to_uppercase();\n   269→\n   270→    for (pattern, series_id) in rules {\n   271→        let upper_pattern = pattern.to_uppercase();\n   272→        if upper_label.contains(&upper_pattern) || upper_original.contains(&upper_pattern) {\n   273→            return Some(*series_id);\n   274→        }\n   275→    }\n   276→    None\n   277→}\n   278→"}]},"parent_tool_use_id":"toolu_01Hm2Mw1V5btHMAHuWJVjTvE","session_id":"9ce4516d-2f05-402b-bc42-9293390160fd","uuid":"3f5eb7af-b0b4-4b17-8458-a066f81f4cb8","timestamp":"2026-03-17T17:00:46.110Z"}
