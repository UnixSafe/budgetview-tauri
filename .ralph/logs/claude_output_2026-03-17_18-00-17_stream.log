→\t\t\t\t GROUP BY series_id`,\n    43→\t\t\t\t[startDate, endDate]\n    44→\t\t\t);\n    45→\n    46→\t\t\tconst actualMap = new Map(actuals.map((a) => [a.series_id, a.total]));\n    47→\t\t\tconst budgetMap = new Map(this.monthlyBudgets.map((b) => [b.series_id, b.planned_amount]));\n    48→\n    49→\t\t\tthis.budgetLines = this.series.map((s) => {\n    50→\t\t\t\tconst planned = budgetMap.get(s.id) ?? s.target_amount ?? 0;\n    51→\t\t\t\tconst actual = actualMap.get(s.id) ?? 0;\n    52→\t\t\t\treturn {\n    53→\t\t\t\t\tseries_id: s.id,\n    54→\t\t\t\t\tseries_name: s.name,\n    55→\t\t\t\t\tbudget_area: s.budget_area,\n    56→\t\t\t\t\tplanned_amount: planned,\n    57→\t\t\t\t\tactual_amount: actual\n    58→\t\t\t\t};\n    59→\t\t\t});\n    60→\t\t} catch (e) {\n    61→\t\t\tthis.error = e instanceof Error ? e.message : 'Erreur inconnue';\n    62→\t\t} finally {\n    63→\t\t\tthis.loading = false;\n    64→\t\t}\n    65→\t}\n    66→\n    67→\tasync createSeries(data: { name: string; budget_area: BudgetArea; target_amount?: number; description?: string }) {\n    68→\t\tawait execute(\n    69→\t\t\t'INSERT INTO budget_series (name, budget_area, target_amount, description) VALUES ($1, $2, $3, $4)',\n    70→\t\t\t[data.name, data.budget_area, data.target_amount ?? null, data.description ?? null]\n    71→\t\t);\n    72→\t\tawait this.loadBudgetView();\n    73→\t}\n    74→\n    75→\tasync updateSeries(id: number, data: Partial<{ name: string; budget_area: BudgetArea; target_amount: number | null; description: string | null }>) {\n    76→\t\tconst fields: string[] = [];\n    77→\t\tconst values: unknown[] = [];\n    78→\t\tlet i = 1;\n    79→\n    80→\t\tfor (const [key, val] of Object.entries(data)) {\n    81→\t\t\tif (val !== undefined) {\n    82→\t\t\t\tfields.push(`${key} = $${i++}`);\n    83→\t\t\t\tvalues.push(val);\n    84→\t\t\t}\n    85→\t\t}\n    86→\n    87→\t\tif (fields.length > 0) {\n    88→\t\t\tvalues.push(id);\n    89→\t\t\tawait execute(`UPDATE budget